# Cloud Build ignore file
# This file controls what gets uploaded to Cloud Build

# Use .gitignore as base
#!include:.gitignore

# Explicitly ignore these (from .gitignore)
/build/
*.whl
.langgraph_api/
# Secrets (only root-level secrets/ dir, not code modules in src/)
/secrets/*
config/*.env
.venv/
.cursor/*
.hypothesis/
.pydantic_cache/
.nox/
.pytest_cache/
__pycache__/
*.py[cod]
*$py.class
.Python
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.mypy_cache/
.ruff_cache/
.env
.env.*
test_logs/
test_results*.log
test_run*.log
*_detail.log
build.log
test-execution.log
test-results/
.agent/
test_data/*/

# Git directory
.git/

# Do NOT ignore these (needed for build)
# !uv.lock - included by default since not in ignore list
# !pyproject.toml
# !Dockerfile.test
