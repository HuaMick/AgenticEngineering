  "implementation_notes": {
    "python": {
      "library": "PyNaCl",
      "installation": "pip install pynacl",
      "example_code": [
        "from nacl.public import PrivateKey, Box",
        "from nacl.encoding import Base64Encoder",
        "",
        "# Load keys",
        "desktop_private = PrivateKey(base64.b64decode(private_key_base64))",
        "client_public = PublicKey(base64.b64decode(public_key_base64))",
        "",
        "# Create box for encryption",
        "box = Box(desktop_private, client_public)",
        "",
        "# Encrypt",
        "nonce = nacl.utils.random(Box.NONCE_SIZE)",
        "plaintext = message.encode('utf-8')",
        "ciphertext = box.encrypt(plaintext, nonce).ciphertext",
        "",
        "# Decrypt",
        "decrypted = box.decrypt(ciphertext, nonce)",
        "message = decrypted.decode('utf-8')"
      ]
    },
    "flutter": {
      "library": "flutter_sodium or pointycastle",
      "installation": "flutter pub add flutter_sodium",
      "example_code": [
        "import 'package:flutter_sodium/flutter_sodium.dart';",
        "import 'dart:convert';",
        "",
        "// Load keys",
        "final desktopPrivate = base64Decode(privateKeyBase64);",
        "final clientPublic = base64Decode(publicKeyBase64);",
        "",
        "// Encrypt",
        "final nonce = Sodium.randomBytes(CryptoBox.nonceBytes);",
        "final plaintext = utf8.encode(message);",
        "final ciphertext = CryptoBox.easy(",
        "  message: plaintext,",
        "  nonce: nonce,",
        "  publicKey: clientPublic,",
        "  secretKey: desktopPrivate,",
        ");",
        "",
        "// Decrypt",
        "final decrypted = CryptoBox.openEasy(",
        "  cipherText: ciphertext,",
        "  nonce: nonce,",
        "  publicKey: desktopPublic,",
        "  secretKey: clientPrivate,",
        ");",
        "final message = utf8.decode(decrypted);"
      ]
    },
