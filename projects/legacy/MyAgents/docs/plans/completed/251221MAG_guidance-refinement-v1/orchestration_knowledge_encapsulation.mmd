%% Orchestration Process: Knowledge Encapsulation Plan Execution
%% Generated: 2025-12-22
%% Plan: docs/plans/live/251221MAG_guidance-refinement-v1/live/plan_knowledge_encapsulation.yml
%%
%% This diagram documents the orchestration decisions made during plan execution,
%% including agent spawning decisions, deviations from plan, and justifications.
    subgraph INIT["INITIALIZATION"]
        A[Read Plan File] --> B[Analyze 3 Phases]
        B --> C[Check Prerequisites]

        %% DECISION: Read related definitions first
        %% JUSTIFICATION: The plan references context-minimisation.yml, signal-and-noise.yml,
        %% and role-separation.yml as related definitions. Reading these provides context
        %% for understanding how knowledge-encapsulation.yml fits into the existing
        %% definition ecosystem and ensures consistency in style/structure.
        C --> D[Read Related Definitions]
        D --> E{Prerequisites Met?}
    end

    subgraph PHASE1["PHASE 1: Create Definition"]
        E -->|Yes| F[Task 1.1: Create knowledge-encapsulation.yml]

        %% DECISION: Spawn teacher-update-assets agent
        %% JUSTIFICATION:
        %%   1. Plan explicitly specifies agent_type: teacher-update-assets
        %%   2. Execute_Plan.yml guideline: "Offload work to appropriate agents"
        %%   3. teacher-update-assets process validates structure against definition.yml
        %%   4. Agent checks for duplicates and follows asset conventions
        %%   5. Content is provided in plan, but agent adds value through validation
        F --> G[SPAWN: teacher-update-assets-agent]
        G --> H{Agent Success?}
        H -->|Yes| I[Verify File Created]
        H -->|No| FAIL1[Escalate to User]
    end

    subgraph PHASE2["PHASE 2: Integrate into Agent Inputs"]
        I --> J[Task 2.1-2.3: Update 3 inputs.yml files]

        %% DECISION: Perform edits directly instead of spawning agents
        %% JUSTIFICATION:
        %%   1. Plan specifies teacher-update-assets for these tasks
        %%   2. HOWEVER: teacher-update-assets process is designed for assets/ folder
        %%   3. These tasks update agents/*/inputs.yml (not assets/)
        %%   4. The edits are mechanical: add one entry to core_inputs section
        %%   5. Content is fully specified in plan - no judgment required
        %%   6. Spawning 3 agents for simple YAML edits = overhead without value
        %%   7. DEVIATION DOCUMENTED: Agent type mismatch justifies direct execution
        J --> K[DIRECT EDIT: planner-teach/inputs.yml]
        J --> L[DIRECT EDIT: teacher-process/inputs.yml]
        J --> M[DIRECT EDIT: teacher-update-assets/inputs.yml]

        %% DECISION: Execute edits in parallel
        %% JUSTIFICATION:
        %%   1. The 3 files are independent (no shared state)
        %%   2. Edit tool calls can be batched in single message
        %%   3. Reduces wall-clock time vs sequential execution
        K & L & M --> N{All Edits Successful?}
        N -->|Yes| O[Phase 2 Complete]
        N -->|No| FAIL2[Escalate to User]
    end

    subgraph PHASE3["PHASE 3: Verification"]
        O --> P[Task 3.1: Validate references and YAML]

        %% DECISION: Perform verification directly instead of spawning test-final-output
        %% JUSTIFICATION:
        %%   1. Plan specifies test-final-output agent
        %%   2. HOWEVER: test-final-output is for interrogating execution data
        %%      ("Interrogate execution data to verify accuracy and completeness")
        %%   3. This task is file validation, not execution data audit
        %%   4. Simple checks: YAML syntax + file existence
        %%   5. Python yaml.safe_load is definitive YAML validation
        %%   6. test -f is definitive file existence check
        %%   7. DEVIATION DOCUMENTED: Agent purpose mismatch justifies direct verification
        P --> Q[DIRECT: Validate YAML syntax - 4 files]
        P --> R[DIRECT: Verify file references exist]
        Q & R --> S{Verification Passed?}
        S -->|Yes| T[All Phases Complete]
        S -->|No| FAIL3[Report Failures]
    end

    subgraph SUMMARY["EXECUTION SUMMARY"]
        T --> U[Generate Orchestration Documentation]
        U --> V[Plan Execution Complete]
    end

    %% Styling
    style G fill:#90EE90,stroke:#228B22
    style K fill:#87CEEB,stroke:#4169E1
    style L fill:#87CEEB,stroke:#4169E1
    style M fill:#87CEEB,stroke:#4169E1
    style Q fill:#DDA0DD,stroke:#8B008B
    style R fill:#DDA0DD,stroke:#8B008B
    style FAIL1 fill:#FFB6C1,stroke:#DC143C
    style FAIL2 fill:#FFB6C1,stroke:#DC143C
    style FAIL3 fill:#FFB6C1,stroke:#DC143C

