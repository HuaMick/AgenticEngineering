flowchart LR
    %% GOAL: Orchestrate agents to implement code changes, features, or bug fixes.
    %% PROFILE: Orchestration-Builder
    %% OUTPUT: Implemented code, tests, and completed plans in docs/plans/completed/
    %% GUIDELINE: BUILD FOCUS policy - code implementation and testing, not guidance-only changes.
    %% GUIDELINE: Every test failure, CI/CD failure, or audit failure MUST trigger a return to the planning stage.
    %% GUIDELINE: assets/guidelines/orchestration-policy.yml - Agent spawning rules, escalation, status management
    %% GUIDELINE: assets/guidelines/user-story-testing.yml - User simulator testing patterns
    %% GUIDELINE: assets/guidelines/testing.yml - Testing strategies and validation
    %% INPUT_PATH: agents/orchestration/orchestration-build/inputs.yml

    Start((Start)) --> LoadInputs[Load Context Inputs]

    %% Input Verification & Search Logic: Ensure we have all necessary context from inputs.yml
    LoadInputs --> ReviewInputs[Review All Listed Inputs]
    ReviewInputs --> CheckInputs{All Inputs Found?}

    %% If inputs are missing, attempt to self-heal by searching
    CheckInputs -- "No: Missing" --> SearchInputs[Search for Missing Inputs]
    SearchInputs --> Found{Found?}

    %% If found elsewhere, update paths to maintain continuity
    Found -- "Yes: Update paths" --> UpdateRefs[Update References & Flag]
    UpdateRefs --> ReviewInputs

    %% Critical failure: Stop and ask user if context cannot be resolved
    Found -- "No: Stop" --> AskUser((Ask User for Clarification))

    %% Proceed only when context is fully loaded and verified
    CheckInputs -- "Yes: Verified" --> SpawnDeployWorktree[Spawn deploy-worktree Agent]

    %% Isolate work and initialize the planning environment
    %% deploy-worktree agent handles worktree setup and verification per its internal criteria
    SpawnDeployWorktree --> VerifyWorktree[Verify Worktree & Planning Folder]
    VerifyWorktree --> WorktreeValid{Worktree Valid?}
    WorktreeValid -- "No: Failed verification" --> AskUser

    %% ========================================
    %% EXPLORATION PHASE
    %% ========================================
    %% LOOP_DEFINITION: assets/definitions/agent-loops.yml#exploration-loop
    %% MAX_ITERATIONS: 3 (per exploration-loop definition)
    %% ESCALATION: If max iterations reached, proceed with available context
    %%
    %% BEHAVIOR: Discovery before planning - understand existing architecture
    %% Build orchestration MUST explore before planning to understand:
    %% - Existing code patterns and conventions
    %% - External dependencies and integrations
    %% - Existing test patterns and coverage
    WorktreeValid -- "Yes: Verified" --> ExplorePhase[Enter Exploration Phase]

    subgraph Exploration ["Exploration Phase Subgraph"]
        %% Spawn multiple explore agents in parallel for comprehensive discovery
        %% - explore-codebase: Existing code patterns, conventions, architecture
        %% - explore-dependencies: External dependencies, integrations
        %% - explore-tests: Existing test patterns, coverage, frameworks
        ExplorePhase --> ExploreCodebase[Spawn explore-codebase Agent]
        ExplorePhase --> ExploreDeps[Spawn explore-dependencies Agent]
        ExplorePhase --> ExploreTests[Spawn explore-tests Agent]
        ExploreCodebase --> ExploreSynthesis[Synthesize Architectural Context]
        ExploreDeps --> ExploreSynthesis
        ExploreTests --> ExploreSynthesis
    end

    %% ========================================
    %% PLANNING & REVIEW SUBGRAPH
    %% ========================================
    %% Both implementation and test plans must be approved before execution begins.
    %% This ensures build quality is validated BEFORE implementation.
    %%
    %% FEEDBACK LOOP ENTRY POINTS:
    %% This phase receives feedback from four downstream validation points:
    %% 1. Test Failures (line 119): Build tests fail --> Update plan and re-plan
    %% 2. CI/CD Failures (line 141): Pipeline fails --> Update plan and re-plan
    %% 3. Guidance Test Failures (line 164): Walkthrough gaps --> Re-execute planning loops
    %% 4. Final Audit Failures (line 179): Output quality issues --> Update plan and re-plan
    %%
    %% When re-entering from test/CI/CD failures:
    %% - planner-build receives structured failure report with specific failure details
    %% - Both Build Planning Loop and Test Planning Loop re-run
    %% - This ensures fixes don't create inconsistencies between build and test plans

    ExploreSynthesis --> PlanningReview[Enter Planning & Review Phase]

    subgraph Planning ["Planning & Review Subgraph"]
        %% ----------------------------------------
        %% LOOP 1: BUILD IMPLEMENTATION PLANNING LOOP
        %% ----------------------------------------
        %% LOOP_DEFINITION: assets/definitions/agent-loops.yml#planner-loop
        %% MAX_ITERATIONS: 5 (per planner-loop definition)
        %% ESCALATION: If max iterations reached without approval, stop and Ask User with iteration context
        %%
        %% FEEDBACK HANDLING:
        %% When returning from downstream failures:
        %% - planner-build receives structured failure report
        %% - Failure types: TEST_FAILURE, CICD_FAILURE, GUIDANCE_GAP, AUDIT_FAILURE
        %% - planner-build updates plan to address root cause
        %% - Plan must be re-approved by planner-reviewer before proceeding
        PlanningReview --> BuildPlanningLoop{Build Implementation Planning Loop}

        BuildPlanningLoop --> SpawnPlannerBuild[Spawn planner-build Agent]
        SpawnPlannerBuild --> SpawnBuildReviewer[Spawn planner-reviewer Agent]

        %% Quality Gate: Reviewer must approve the build implementation plan
        SpawnBuildReviewer --> BuildPlanApproved{Build Plan Approved?}

        %% Iterative refinement: Reuse planner-build to address reviewer feedback
        BuildPlanApproved -- "No: Refine" --> SpawnPlannerBuildFix[Spawn planner-build Agent]
        SpawnPlannerBuildFix --> SpawnBuildReviewer

        %% ----------------------------------------
        %% LOOP 2: BUILD TEST PLANNING LOOP
        %% ----------------------------------------
        %% This loop runs AFTER build planning is approved
        %% Plans the test validation strategy for the build
        %% GUIDELINE: assets/guidelines/testing.yml
        %% GUIDELINE: assets/guidelines/user-story-testing.yml
        BuildPlanApproved -- "Yes: Ready" --> TestPlanningLoop{Build Test Planning Loop}

        TestPlanningLoop --> SpawnTestPlanner[Spawn planner-test Agent]
        SpawnTestPlanner --> SpawnTestReviewer[Spawn planner-reviewer Agent]

        %% Quality Gate: Reviewer must approve the test plan
        SpawnTestReviewer --> TestPlanApproved{Test Plan Approved?}

        %% Iterative refinement for test plan
        TestPlanApproved -- "No: Refine" --> SpawnTestPlannerFix[Spawn planner-test Agent]
        SpawnTestPlannerFix --> SpawnTestReviewer

        %% Check for test planning failures that require returning to build planning
        TestPlanApproved -- "Yes: Check Viability" --> TestPlanViable{Test Plan Viable?}

        %% If test plan reveals build plan issues, return to build planning
        TestPlanViable -- "No: Build Issues Found" --> UpdateBuildPlan[Update Build Plan]
        UpdateBuildPlan -.->|Return to Loop 1| BuildPlanningLoop
    end

    %% NOTE: Test Plan (from Loop 2) drives test execution in Implementation Phase
    %% The approved test plan defines which tests will validate the build

    %% ========================================
    %% IMPLEMENTATION PHASE: Build Agents Execute Plan
    %% ========================================
    %% LOOP_DEFINITION: assets/definitions/agent-loops.yml#test-fix-loop
    %% MAX_ITERATIONS: 5 (per test-fix-loop definition)
    %% ESCALATION: If max iterations reached without tests passing, stop and Ask User
    %%
    %% Execution begins ONLY after both plans are approved:
    %% - Build implementation plan approved (planner-build)
    %% - Test plan approved (planner-test)
    TestPlanViable -- "Yes: Both Plans Ready" --> ExecutePhases[Execute Implementation Phases]

    subgraph Implementation ["Implementation Loop Subgraph"]
        %% BEHAVIOR: Build agents implement the approved plan
        %% - build-python: Python implementation tasks
        %% - build-flutter: Flutter/Dart implementation tasks
        %% - test-runner: Execute tests after implementation
        %%
        %% FAIL-FAST: On test failure, categorize and handle:
        %% - Unit test failure: Fix in current iteration
        %% - Integration test failure: May require plan update
        %% - E2E test failure: Escalate to planning phase
        ExecutePhases --> SpawnBuilders[Spawn build-python/flutter agents]
        SpawnBuilders --> RunTests[Spawn test-runner]
        RunTests --> TestsPassed{Tests Passed?}
        TestsPassed -- "No: Fix in Iteration" --> SpawnBuilders
    end

    %% Test failure escalation path for severe issues
    TestsPassed -- "No: Escalate" --> CategorizeTestFailure[Categorize Test Failure]
    CategorizeTestFailure --> UpdatePlanTests[Update Plan with Test Failure Details]
    UpdatePlanTests -.->|Return to Planning| PlanningReview

    %% ========================================
    %% CI/CD VALIDATION PHASE
    %% ========================================
    %% Validate pipeline configuration if build changes affect CI/CD
    %% deploy-cicd agent audits pipeline changes for correctness
    %%
    %% BEHAVIOR: Validate CI/CD pipeline changes
    %% - deploy-cicd agent audits pipeline configuration
    %% - Validates GitHub Actions, Docker, deployment scripts
    %% - On failure: Categorize issue and route appropriately
    %%
    %% FAILURE HANDLING:
    %% - Configuration errors: Return to planning for fix
    %% - Syntax errors: Fix in place, re-validate
    %% - Integration issues: May require build plan update
    TestsPassed -- "Yes: Passed" --> CICDCheck{CI/CD Changes?}
    CICDCheck -- "Yes" --> SpawnDeploy[Spawn deploy-cicd Audit]
    SpawnDeploy --> CICDValid{CI/CD Valid?}

    %% CI/CD failure categorization
    CICDValid -- "No: Categorize" --> CategorizeCICDFailure[Categorize CI/CD Failure]
    CategorizeCICDFailure --> UpdatePlanCICD[Update Plan with CI/CD Issues]
    UpdatePlanCICD -.->|Return to Planning| PlanningReview

    %% ========================================
    %% GUIDANCE VALIDATION PHASE
    %% ========================================
    %% Validate any new/updated guidance created during build
    %% Uses guidance-blind-test strategy to validate guidance completeness
    %% GUIDELINE: assets/definitions/strategy-guidance-blind-test.yml
    %% LOOP_DEFINITION: assets/definitions/agent-loops.yml#guidance-test-loop
    %% MAX_ITERATIONS: 3 (per guidance-test-loop definition)
    %% ESCALATION: If max iterations reached without passing validation, stop and Ask User with gap context
    CICDCheck -- "No" --> GuidanceChanges{Guidance Changes?}
    CICDValid -- "Yes: Valid" --> GuidanceChanges
    GuidanceChanges -- "Yes" --> GuidanceTest[Spawn planner-test-guidance]
    GuidanceTest --> GuidanceSimulator[Spawn test-guidance-simulator]

    %% PLAN STATUS UPDATE: Consume test results and update plan task statuses
    %% Reference: assets/guidelines/orchestration-policy.yml - Plan Status Management rule
    %% This step ensures task statuses reflect test outcomes before evaluating overall guidance validity
    GuidanceSimulator --> UpdateGuidanceStatuses[Update Plan Task Statuses from Test Results]
    UpdateGuidanceStatuses --> GuidancePassed{Guidance Valid?}

    %% ========================================
    %% GUIDANCE REPAIR LOOP: Failing walkthrough tests trigger return to Planning
    %% ========================================
    %% BEHAVIOR: When test-guidance-simulator reports friction points:
    %% 1. Categorize gaps by severity (CRITICAL/HIGH/MEDIUM/LOW from test-guidance-simulator)
    %% 2. Route to appropriate handler based on gap type:
    %%    - Build process issues: Return to Build Planning Loop (planner-build)
    %%    - Test design issues: Return to Test Planning Loop (planner-test)
    %%    - Guidance issues: Route through planner-teach
    %% 3. Update plan with structured friction report
    %% 4. Re-execute BOTH planning loops to ensure consistency
    %% 5. Track iteration count against guidance-test-loop max_iterations (3)
    %% ========================================
    GuidancePassed -- "No: Gaps Found" --> CategorizeGuidanceGaps[Categorize Friction Points]
    CategorizeGuidanceGaps --> RouteToHandler{Route by Gap Type}
    RouteToHandler -- "Build Process" --> UpdatePlanBuild[Update Build Plan]
    RouteToHandler -- "Test Design" --> UpdatePlanTest[Update Test Plan]
    RouteToHandler -- "Guidance" --> UpdatePlanGuidance[Update Guidance Plan]
    UpdatePlanBuild -.->|Return to Planning| PlanningReview
    UpdatePlanTest -.->|Return to Planning| PlanningReview
    UpdatePlanGuidance -.->|Return to Planning| PlanningReview

    %% ========================================
    %% FINAL AUDIT PHASE
    %% ========================================
    GuidanceChanges -- "No" --> SpawnFinalAudit[Spawn test-final-output Audit]
    GuidancePassed -- "Yes: Verified" --> SpawnFinalAudit

    SpawnFinalAudit --> FinalAudit{Final Audit Passed?}

    %% If audit fails, loop back to Planning & Review phase for correction
    FinalAudit -- "No: Failed" --> UpdatePlanAudit[Update Plan with Audit Issues]
    UpdatePlanAudit -.->|Return to Planning| PlanningReview

    %% ========================================
    %% FINALIZATION
    %% ========================================
    %% Success: All criteria met. Finalize the work.
    FinalAudit -- "Yes: Verified" --> MoveCompleted[Copy Completed Work to docs/plans/completed/]
    MoveCompleted --> End((End))

    %% COPY planning folder to completed/ (not move) - live/ may continue with follow-on work
    %% Only user moves completed/ folders to archived/ subdirectory

    %% Styling for feedback loops (return paths to Planning & Review)
    %% These dotted lines represent quality improvement cycles:
    %% - Test failure returns (from Implementation Phase)
    %% - CI/CD failure returns (from CI/CD Validation Phase)
    %% - Guidance gap returns (from Guidance Validation Phase)
    %% - Audit failure returns (from Final Audit Phase)
    %% - Test plan viability returns (from Test Planning Loop)
    classDef dashedstroke stroke-dasharray: 5 5;
    linkStyle 34,42,48,60,61,62,67 stroke:#888,stroke-width:2px,stroke-dasharray: 5 5;
