%% =============================================================================
%% GOAL: Remove ALL backward-compatible hidden aliases from the CLI and replace with helpful error messages that direct users to the correct commands. Simultaneously update all agent process files and guidance assets that reference the old command paths to use the new 'agentic agent ...' prefix paths. This is a two-track change: (1) break the old aliases in CLI so they emit clear guidance messages and exit 1, (2) update all agent instruction files so spawned agents use correct paths from day one.

%% =============================================================================
%% PROFILE: Orchestration-Remove backward-compatible aliases
%% INPUT_PATH: /home/code/AgenticEngineering/docs/plans/live/260221NE_remove_backward_compat_aliases/plan_build.yml
%%
%% PHASES:
%%   P1: Update Agent Process Files
%%   P2: Replace CLI Aliases with Deprecation Stubs
%%   P3: Update Tests
%%
%% AGENT_ROUTING: P1 -> build-python, P2 -> build-python, P3 -> test-builder
%% STATUS: P1=pending, P2=pending, P3=pending
%% FEEDBACK_TRIGGERS: TEST_FAILURE -> test-fix-loop, BUILD_FAILURE -> escalate
%% =============================================================================

flowchart LR
    Start((Start)) --> LoadInputs[Load Context Inputs]

    %% ========================================
    %% INPUT VALIDATION PHASE
    %% ========================================
    LoadInputs --> ReviewInputs[Review All Listed Inputs]
    ReviewInputs --> CheckInputs{All Inputs Found?}

    CheckInputs -- "No: Missing" --> SearchInputs[Search for Missing Inputs]
    SearchInputs --> Found{Found?}
    Found -- "Yes: Update paths" --> UpdateRefs[Update References]
    UpdateRefs --> ReviewInputs
    Found -- "No: Stop" --> AskUser((Ask User for Clarification))

    CheckInputs -- "Yes: Verified" --> Phase1

    %% ========================================
    %% PHASE 1: UPDATE AGENT PROCESS FILES
    %% ========================================
    %% AGENT_ROUTING: build-python agent

    subgraph P1_SG ["Update Agent Process Files"]
        Phase1[Enter Update Agent Process Files] --> SpawnAgent1[Spawn build-python Agent]
        SpawnAgent1 --> Phase1Complete[Update Agent Process Files Complete]
    end

    Phase1Complete --> Phase2

    %% ========================================
    %% PHASE 2: REPLACE CLI ALIASES WITH DEPRECATION STUBS
    %% ========================================
    %% AGENT_ROUTING: build-python agent

    subgraph P2_SG ["Replace CLI Aliases with Deprecation Stubs"]
        Phase2[Enter Replace CLI Aliases with Deprecation Stubs] --> SpawnAgent2[Spawn build-python Agent]
        SpawnAgent2 --> Phase2Complete[Replace CLI Aliases with Deprecation Stubs Complete]
    end

    Phase2Complete --> Phase3

    %% ========================================
    %% PHASE 3: UPDATE TESTS
    %% ========================================
    %% AGENT_ROUTING: test-builder agent with test-fix loop
    %% LOOP_DEFINITION: test-fix-loop
    %% MAX_ITERATIONS: 5

    subgraph Testing3_SG ["Update Tests (Test-Fix-Loop)"]
        Phase3[Enter Update Tests] --> SpawnTestBuilder3[Spawn test-builder Agent]
        SpawnTestBuilder3 --> RunTests3[Run Tests]
        RunTests3 --> TestsPassed3{Tests Passed?}

        %% Test-Fix Loop: retry path
        TestsPassed3 -- "No: Fix in Iteration" --> SpawnBuilderFix3[Spawn builder Agent for Fixes]
        SpawnBuilderFix3 --> ApplyFixes3[Apply Implementation Fixes]
        ApplyFixes3 --> RunTests3

        %% Success path
        TestsPassed3 -- "Yes: All Pass" --> Phase3Complete[Update Tests Complete]
    end

    %% Escalation path for persistent test failures
    TestsPassed3 -- "No: Escalate" --> CheckIterations3{Max Iterations Reached?}
    CheckIterations3 -- "No" --> SpawnTestBuilder3
    CheckIterations3 -- "Yes" --> EscalateTests3((Ask User: Test Failures Persist))


    %% ========================================
    %% FINALIZATION
    %% ========================================
    Phase3Complete --> UpdatePlanStatus[Update Plan Status: completed]
    %% agentic plan move folder --plan <path>
    UpdatePlanStatus --> ArchivePlan[Archive to docs/plans/completed/]
    ArchivePlan --> End((End: Plan Complete))

    %% ========================================
    %% STYLING
    %% ========================================
    classDef entrypoint fill:#90EE90,stroke:#228B22
    classDef exitpoint fill:#FFB6C1,stroke:#DC143C
    classDef userpoint fill:#87CEEB,stroke:#4682B4
    classDef keyaction fill:#FFD700,stroke:#DAA520
    class Start entrypoint
    class End exitpoint
    class AskUser,EscalateTests3 userpoint
