    classDef decision fill:#fff9c4,stroke:#f57f17
    classDef feedbackLoop fill:#ffcdd2,stroke:#c62828

    class P1_SG buildPhase
    class P2_SG testPhase
    class P3_SG blindTestPhase
    class P4_SG reviewPhase
    class P5_SG guidancePhase
    class BlindTestResult,ReviewResult,AllPass,RunTests decision
    class AnalyzeFailure,FixIssues,DebugFinal,FixTests feedbackLoop
