flowchart TD
    Start((Start)) --> LoadPlan[Load plan_build.yml]

    %% ========================================
    %% PHASE 1: BUILD - FIX CLI TASK PARSING
    %% ========================================
    LoadPlan --> P1

    subgraph P1_SG ["Phase 1: Build - Fix CLI Task Parsing"]
        P1[Start Build Phase] --> FI001[FI-001: Update _update_task_status]
        FI001 --> FI002[FI-002: Verify cmd_task_list]
        FI002 --> FI003[FI-003: Verify cmd_task_current]
        FI003 --> FI004[FI-004: Verify cmd_task_status]
        FI004 --> P1Complete[Build Phase Complete]
    end

    P1Complete --> P2

    %% ========================================
    %% PHASE 2: TEST - UNIT TESTS
    %% ========================================
    subgraph P2_SG ["Phase 2: Test - Unit Tests"]
        P2[Start Test Phase] --> FI005[FI-005: Create unit tests]
        FI005 --> FI006[FI-006: Test task start]
        FI006 --> FI007[FI-007: Test task complete]
        FI007 --> FI008[FI-008: Test task list]
        FI008 --> RunTests{Run pytest}
