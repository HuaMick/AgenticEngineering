flowchart LR
    %% GOAL: Orchestrate migration of PlanService from YAML files to TinyDB embedded datastore.
    %% PROFILE: Orchestration-Build
    %% OUTPUT: TinyDB-backed PlanRepository, updated PlanService/TaskService, refactored CLI commands.
    %% GUIDELINE: BUILD FOCUS policy - code implementation and testing, not guidance-only changes.
    %% GUIDELINE: Dual-write strategy - writes go to both TinyDB and YAML for backward compatibility.
    %% INPUT_PATH: modules/AgenticGuidance/agents/orchestration/orchestration-executor/inputs.yml

    # AGENT_ROUTING: Foundation -> build-python, ServiceIntegration -> build-python, DataMigration -> build-python, CLIRefactor -> build-python, Validation -> test-runner, Audit -> test-final-output
    # STATUS: InputValidation=pending, Foundation=pending, ServiceIntegration=pending, DataMigration=pending, CLIRefactor=pending, Validation=pending, Audit=pending

    Start((Start)) --> LoadInputs[Load Context Inputs]

    %% ========================================
    %% INPUT VALIDATION PHASE
    %% ========================================
    subgraph InputValidation_SG ["Input Validation Subgraph"]
        LoadInputs --> ReviewInputs[Review Plan & Source Files]
        ReviewInputs --> CheckInputs{All Inputs Found?}
        CheckInputs -- "No: Missing" --> AskUser((Ask User for Clarification))
        CheckInputs -- "Yes: Verified" --> EnterFoundation
    end

    %% ========================================
    %% PHASE 1: FOUNDATION & DEPENDENCIES
    %% ========================================
    %% Tasks: DB_001 (Add TinyDB dep), DB_002 (Create PlanRepository)
    subgraph Foundation_SG ["Phase 1: Foundation & Dependencies"]
        EnterFoundation[Enter Foundation Phase] --> SpawnDB001[Spawn build-python Agent]
        SpawnDB001 --> CheckDB001{DB_001 Complete?}
        CheckDB001 -- "No: Fix" --> SpawnDB001
        CheckDB001 -- "Yes" --> SpawnDB002[Spawn build-python Agent]
        SpawnDB002 --> CheckDB002{DB_002 Complete?}
        CheckDB002 -- "No: Fix" --> SpawnDB002
        CheckDB002 -- "Yes" --> EnterServiceIntegration
    end

    %% ========================================
    %% PHASE 2: SERVICE LAYER INTEGRATION
    %% ========================================
    %% Tasks: SV_001 (PlanService), SV_002 (TaskService), SV_003 (Exports)
    subgraph ServiceIntegration_SG ["Phase 2: Service Layer Integration"]
        EnterServiceIntegration[Enter Service Integration] --> SpawnSV001[Spawn build-python Agent]
        SpawnSV001 --> CheckSV001{SV_001 Complete?}
        CheckSV001 -- "No: Fix" --> SpawnSV001
        CheckSV001 -- "Yes" --> SpawnSV002SV003[Spawn build-python Agent]
        SpawnSV002SV003 --> CheckSV002{SV_002 & SV_003 Complete?}
        CheckSV002 -- "No: Fix" --> SpawnSV002SV003
        CheckSV002 -- "Yes" --> RunServiceTests[Spawn test-runner]
        RunServiceTests --> ServiceTestsPassed{Service Tests Passed?}
        ServiceTestsPassed -- "No: Fix" --> SpawnSV001
        ServiceTestsPassed -- "Yes" --> EnterDataMigration
    end

    %% ========================================
    %% PHASE 3: DATA MIGRATION & SYNC
    %% ========================================
    %% Tasks: MI_001 (Auto-bootstrap), MI_002 (CLI db sync)
    subgraph DataMigration_SG ["Phase 3: Data Migration & Sync"]
        EnterDataMigration[Enter Data Migration] --> SpawnMI001[Spawn build-python Agent]
        SpawnMI001 --> CheckMI001{MI_001 Complete?}
        CheckMI001 -- "No: Fix" --> SpawnMI001
        CheckMI001 -- "Yes" --> SpawnMI002[Spawn build-python Agent]
        SpawnMI002 --> CheckMI002{MI_002 Complete?}
        CheckMI002 -- "No: Fix" --> SpawnMI002
        CheckMI002 -- "Yes" --> EnterCLIRefactor
    end

    %% ========================================
    %% PHASE 4: CLI LAYER REFACTOR
    %% ========================================
    %% LOOP_DEFINITION: modules/AgenticGuidance/assets/definitions/agent-loops.yml#loop_types.test-fix-loop
    %% MAX_ITERATIONS: 5 (per test-fix-loop definition)
    %% ESCALATION: If max iterations reached without tests passing, stop and Ask User
    %% Tasks: CL_001 (list/status), CL_002 (task CRUD), CL_003 (remaining)
    subgraph CLIRefactor_SG ["Phase 4: CLI Layer Refactor"]
        EnterCLIRefactor[Enter CLI Refactor] --> SpawnCL001[Spawn build-python Agent]
        SpawnCL001 --> CheckCL001{CL_001 Complete?}
        CheckCL001 -- "No: Fix" --> SpawnCL001
        CheckCL001 -- "Yes" --> SpawnCL002[Spawn build-python Agent]
        SpawnCL002 --> CheckCL002{CL_002 Complete?}
        CheckCL002 -- "No: Fix" --> SpawnCL002
        CheckCL002 -- "Yes" --> SpawnCL003[Spawn build-python Agent]
        SpawnCL003 --> CheckCL003{CL_003 Complete?}
        CheckCL003 -- "No: Fix" --> SpawnCL003
        CheckCL003 -- "Yes" --> RunCLITests[Spawn test-runner]
        RunCLITests --> CLITestsPassed{CLI Tests Passed?}
        CLITestsPassed -- "No: Fix in Iteration" --> SpawnCLFix[Spawn build-python Agent]
        SpawnCLFix --> RunCLITests
        CLITestsPassed -- "No: Escalate" --> AskUser
        CLITestsPassed -- "Yes: Passed" --> EnterValidation
    end

    %% ========================================
    %% VALIDATION PHASE
    %% ========================================
    subgraph Validation_SG ["Validation Subgraph"]
        EnterValidation[Enter Validation] --> RunFullTests[Spawn test-runner]
        RunFullTests --> FullTestsPassed{All Tests Passed?}
        FullTestsPassed -- "No: Fix" --> SpawnValidationFix[Spawn build-python Agent]
        SpawnValidationFix --> RunFullTests
        FullTestsPassed -- "Yes" --> SpawnAudit[Spawn test-final-output Audit]
        SpawnAudit --> AuditPassed{Audit Passed?}
        AuditPassed -- "No: Fix" --> SpawnAuditFix[Spawn build-python Agent]
        SpawnAuditFix --> RunFullTests
        AuditPassed -- "Yes" --> Output
    end

    %% ========================================
    %% OUTPUT PHASE
    %% ========================================
    subgraph Output_SG ["Output Subgraph"]
        Output[Generate Output Report] --> Report[Report Results]
    end

    Report --> End((End))

    %% ========================================
    %% FEEDBACK TRIGGERS
    %% ========================================
    # FEEDBACK_TRIGGER: TEST_FAILURE -> SpawnCLFix
    # FEEDBACK_TRIGGER: AUDIT_FAILURE -> SpawnAuditFix

    %% ========================================
    %% STYLING
    %% ========================================
    classDef dashedstroke stroke-dasharray: 5 5;
