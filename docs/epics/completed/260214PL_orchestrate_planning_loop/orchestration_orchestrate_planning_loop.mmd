%% =============================================================================
%% GOAL: Add --planning-loop flag to `agentic orchestrate` that automates the full
%% plan lifecycle: discover plans needing orchestration, spawn planners, run review
%% cycles, generate/validate MMDs, then execute phases by parsing AGENT_ROUTING
%% and spawning the appropriate agents.
%%
%% =============================================================================
%% PROFILE: Orchestration-Planning Loop Automation
%% INPUT_PATH: /home/code/AgenticEngineering/docs/plans/live/260214PL_orchestrate_planning_loop/plan_build.yml
%%
%% PHASES:
%%   phase-1: Orchestration Workflow
%%   phase-2: CLI Integration
%%   phase-3: Tests
%%
%% AGENT_ROUTING: phase-1 -> build-python, phase-2 -> build-python, phase-3 -> test-builder
%% STATUS: phase-1=pending, phase-2=pending, phase-3=pending
%% FEEDBACK_TRIGGERS: TEST_FAILURE -> test-fix-loop, BUILD_FAILURE -> escalate
%% =============================================================================

flowchart LR
    Start((Start)) --> LoadInputs[Load Context Inputs]

    %% ========================================
    %% INPUT VALIDATION PHASE
    %% ========================================
    LoadInputs --> ReviewInputs[Review All Listed Inputs]
    ReviewInputs --> CheckInputs{All Inputs Found?}

    CheckInputs -- "No: Missing" --> SearchInputs[Search for Missing Inputs]
    SearchInputs --> Found{Found?}
    Found -- "Yes: Update paths" --> UpdateRefs[Update References]
    UpdateRefs --> ReviewInputs
    Found -- "No: Stop" --> AskUser((Ask User for Clarification))

    CheckInputs -- "Yes: Verified" --> Phase1

    %% ========================================
    %% PHASE 1: ORCHESTRATION WORKFLOW
    %% ========================================
    %% AGENT_ROUTING: build-python agent
    %% Tasks: task-1.1, task-1.2, task-1.3

    subgraph phase_1_SG ["Orchestration Workflow"]
        Phase1[Enter Orchestration Workflow] --> SpawnAgent1[Spawn build-python Agent]
        SpawnAgent1 --> Task_1_1[task-1.1: Implement parse_mmd_routing pure function]
        Task_1_1 --> Task_1_2[task-1.2: Implement OrchestrationWorkflow class]
        Task_1_2 --> Task_1_3[task-1.3: Implement OrchestrationRunner class]
        Task_1_3 --> Phase1Complete[Orchestration Workflow Complete]
    end

    Phase1Complete --> Phase2

    %% ========================================
    %% PHASE 2: CLI INTEGRATION
    %% ========================================
    %% AGENT_ROUTING: build-python agent
    %% Tasks: task-2.1, task-2.2

    subgraph phase_2_SG ["CLI Integration"]
        Phase2[Enter CLI Integration] --> SpawnAgent2[Spawn build-python Agent]
        SpawnAgent2 --> Task_2_1[task-2.1: Add --planning-loop flag handling to cmd_orchestrate]
        Task_2_1 --> Task_2_2[task-2.2: Register --planning-loop flag in cli.py]
        Task_2_2 --> Phase2Complete[CLI Integration Complete]
    end

    Phase2Complete --> Phase3

    %% ========================================
    %% PHASE 3: TESTS
    %% ========================================
    %% AGENT_ROUTING: test-builder agent with test-fix loop
    %% LOOP_DEFINITION: test-fix-loop
    %% MAX_ITERATIONS: 5

    subgraph Testing3_SG ["Tests (Test-Fix-Loop)"]
        Phase3[Enter Tests] --> SpawnTestBuilder3[Spawn test-builder Agent]
        SpawnTestBuilder3 --> RunTests3[Run Tests]
        RunTests3 --> TestsPassed3{Tests Passed?}

        %% Test-Fix Loop: retry path
        TestsPassed3 -- "No: Fix in Iteration" --> SpawnBuilderFix3[Spawn builder Agent for Fixes]
        SpawnBuilderFix3 --> ApplyFixes3[Apply Implementation Fixes]
        ApplyFixes3 --> RunTests3

        %% Success path
        TestsPassed3 -- "Yes: All Pass" --> Phase3Complete[Tests Complete]
    end

    %% Escalation path for persistent test failures
    TestsPassed3 -- "No: Escalate" --> CheckIterations3{Max Iterations Reached?}
    CheckIterations3 -- "No" --> SpawnTestBuilder3
    CheckIterations3 -- "Yes" --> EscalateTests3((Ask User: Test Failures Persist))

    %% ========================================
    %% FINALIZATION
    %% ========================================
    Phase3Complete --> UpdatePlanStatus[Update Plan Status: completed]
    %% agentic plan move folder --plan <path>
    UpdatePlanStatus --> ArchivePlan[Archive to docs/plans/completed/]
    ArchivePlan --> End((End: Plan Complete))

    %% ========================================
    %% STYLING
    %% ========================================
    classDef entrypoint fill:#90EE90,stroke:#228B22
    classDef exitpoint fill:#FFB6C1,stroke:#DC143C
    classDef userpoint fill:#87CEEB,stroke:#4682B4
    classDef keyaction fill:#FFD700,stroke:#DAA520
    class Start entrypoint
    class End exitpoint
    class AskUser,EscalateTests3 userpoint
