flowchart LR
    Start((Start)) --> LoadInputs[Load Context Inputs]

    %% ========================================
    %% INPUT VALIDATION PHASE
    %% ========================================
    LoadInputs --> ReviewInputs[Review All Listed Inputs]
    ReviewInputs --> CheckInputs{All Inputs Found?}

    CheckInputs -- "No: Missing" --> SearchInputs[Search for Missing Inputs]
    SearchInputs --> Found{Found?}
    Found -- "Yes: Update paths" --> UpdateRefs[Update References]
    UpdateRefs --> ReviewInputs
    Found -- "No: Stop" --> AskUser((Ask User for Clarification))

    CheckInputs -- "Yes: Verified" --> Phase1

    %% ========================================
    %% PHASE 1: FOUNDATION & ASSET MANAGEMENT
    %% ========================================
    %% AGENT_ROUTING: builder agent
    %% Tasks: 1.1, 1.2

    subgraph P1_SG ["Foundation & Asset Management"]
        Phase1[Enter Foundation & Asset Management] --> SpawnAgent1[Spawn builder Agent]
        SpawnAgent1 --> Task_P1_1[1.1: Relocate dashboard HTML template]
        Task_P1_1 --> Task_P1_2[1.2: Update asset loader]
        Task_P1_2 --> Phase1Complete[Foundation & Asset Management Complete]
    end

    Phase1Complete --> Phase2

    %% ========================================
    %% PHASE 2: IMPLEMENTATION REFACTORING
    %% ========================================
    %% AGENT_ROUTING: builder agent
    %% Tasks: 2.1, 2.2

    subgraph P2_SG ["Implementation Refactoring"]
        Phase2[Enter Implementation Refactoring] --> SpawnAgent2[Spawn builder Agent]
        SpawnAgent2 --> Task_P2_1[2.1: Refactor orchestration_server.py]
        Task_P2_1 --> Task_P2_2[2.2: Enhance 'plan orchestration dashboard' subcommand]
        Task_P2_2 --> Phase2Complete[Implementation Refactoring Complete]
    end

    Phase2Complete --> Phase3

    %% ========================================
    %% PHASE 3: TESTING & VALIDATION
    %% ========================================
    %% AGENT_ROUTING: test-builder agent with test-fix loop
    %% LOOP_DEFINITION: test-fix-loop
    %% MAX_ITERATIONS: 5

    subgraph Testing3_SG ["Testing & Validation (Test-Fix-Loop)"]
        Phase3[Enter Testing & Validation] --> SpawnTestBuilder3[Spawn test-builder Agent]
        SpawnTestBuilder3 --> RunTests3[Run Tests]
        RunTests3 --> TestsPassed3{Tests Passed?}

        %% Test-Fix Loop: retry path
        TestsPassed3 -- "No: Fix in Iteration" --> SpawnBuilderFix3[Spawn builder Agent for Fixes]
        SpawnBuilderFix3 --> ApplyFixes3[Apply Implementation Fixes]
        ApplyFixes3 --> RunTests3

        %% Success path
        TestsPassed3 -- "Yes: All Pass" --> Phase3Complete[Testing & Validation Complete]
    end

    %% Escalation path for persistent test failures
    TestsPassed3 -- "No: Escalate" --> CheckIterations3{Max Iterations Reached?}
    CheckIterations3 -- "No" --> SpawnTestBuilder3
    CheckIterations3 -- "Yes" --> EscalateTests3((Ask User: Test Failures Persist))

    Phase3Complete --> Phase4

    %% ========================================
    %% PHASE 4: HARDENING & ERROR HANDLING
    %% ========================================
    %% AGENT_ROUTING: builder agent
    %% Tasks: 4.1, 4.2

    subgraph P4_SG ["Hardening & Error Handling"]
        Phase4[Enter Hardening & Error Handling] --> SpawnAgent4[Spawn builder Agent]
        SpawnAgent4 --> Task_P4_1[4.1: Graceful degradation for missing 'mcp']
        Task_P4_1 --> Task_P4_2[4.2: Security audit of HTML generation]
        Task_P4_2 --> Phase4Complete[Hardening & Error Handling Complete]
    end

    Phase4Complete --> Phase5

    %% ========================================
    %% PHASE 5: UAT & FINAL POLISH
    %% ========================================
    %% AGENT_ROUTING: builder agent
    %% Tasks: 5.1

    subgraph P5_SG ["UAT & Final Polish"]
        Phase5[Enter UAT & Final Polish] --> SpawnAgent5[Spawn builder Agent]
        SpawnAgent5 --> Task_P5_1[5.1: End-to-end verification in Claude Code]
        Task_P5_1 --> Phase5Complete[UAT & Final Polish Complete]
    end


    %% ========================================
    %% FINALIZATION
    %% ========================================
    Phase5Complete --> UpdatePlanStatus[Update Plan Status: completed]
    %% agentic plan move folder --plan <path>
    UpdatePlanStatus --> ArchivePlan[Archive to docs/plans/completed/]
    ArchivePlan --> End((End: Plan Complete))

