flowchart LR
    %% ========================================
    %% HEADER METADATA
    %% ========================================
    %% GOAL: Reduce orchestration-executor context overflow by updating guidance to enforce
    %%       output summarisation, batched polling, state file offloading, JIT manifest loading,
    %%       and agent concurrency limits.
    %% PROFILE: orchestrator
    %% EPIC_FOLDER: docs/epics/live/260303AG_reduce_orchestration_context_overflow/
    %% INPUT_PATH: docs/epics/live/260303AG_reduce_orchestration_context_overflow/plan_build.yml
    %% OUTPUT_PATH: orchestration_reduce_orchestration_context_overflow.mmd
    %% PHASES: Phase1_QuickWins, Phase2_SpecAlignment, Phase3_Audit
    %% AGENT_ROUTING: Phase1_QuickWins -> teacher, Phase2_SpecAlignment -> teacher, Phase3_Audit -> auditor
    %% FEEDBACK_TRIGGER: AUDIT_FAILURE -> AuditFixLoop
    %% STATUS: Phase1_QuickWins=pending, Phase2_SpecAlignment=pending, Phase3_Audit=pending
    %% LOOP_DEFINITION: modules/AgenticGuidance/assets/definitions/agent-loops.yml#loop_types.audit-test-fix-loop
    %% MAX_ITERATIONS: 3 (per audit-test-fix-loop definition)
    %% ESCALATION: If max iterations reached without resolution, stop and Ask User

    %% ========================================
    %% START NODE
    %% ========================================
    Start((Start)) --> LoadPlan[Load plan_build.yml]

    %% ========================================
    %% INPUT VALIDATION
    %% ========================================
    subgraph InputValidation_SG ["Input Validation"]
        LoadPlan --> CheckInputs{Epic folder\nand plan found?}
        CheckInputs -- "No" --> AskUser((Ask User))
        CheckInputs -- "Yes" --> Phase1
    end

    %% ========================================
    %% PHASE 1: QUICK WIN GUIDANCE CHANGES
    %% ========================================
    %% Agent: teacher (teacher-update-guidance)
    %% Tickets: teach_01, teach_02, teach_03, teach_04, teach_05
    subgraph Phase1_SG ["Phase 1: Quick Win Guidance Changes (teacher)"]
        Phase1[Phase 1:\nQuick Wins] --> SpawnTeacher1[Spawn teacher-update-guidance\nfor teach_01..05]
        SpawnTeacher1 --> Phase1Done{5 guidance\ntickets complete?}
        Phase1Done -- "No: Retry" --> SpawnTeacher1
        Phase1Done -- "Yes" --> Phase2
    end

    %% ========================================
    %% PHASE 2: SPECIFICATION ALIGNMENT
    %% ========================================
    %% Agent: teacher (teacher-update-guidance)
    %% Tickets: teach_06, teach_07
    subgraph Phase2_SG ["Phase 2: Specification Alignment (teacher)"]
        Phase2[Phase 2:\nSpec Alignment] --> SpawnTeacher2[Spawn teacher-update-guidance\nfor teach_06..07]
        SpawnTeacher2 --> Phase2Done{2 spec\ntickets complete?}
        Phase2Done -- "No: Retry" --> SpawnTeacher2
        Phase2Done -- "Yes" --> Phase3
    end

    %% ========================================
    %% PHASE 3: AUDIT AND VALIDATION
    %% ========================================
    %% Agent: auditor (test-final-output)
    %% Ticket: audit_01
    %% LOOP_DEFINITION: modules/AgenticGuidance/assets/definitions/agent-loops.yml#loop_types.audit-test-fix-loop
    %% MAX_ITERATIONS: 3
    subgraph Phase3_SG ["Phase 3: Audit and Validation (auditor)"]
        Phase3[Phase 3:\nAudit] --> SpawnAuditor[Spawn test-final-output\nfor audit_01]
        SpawnAuditor --> AuditCheck{Audit\nPASS?}
        AuditCheck -- "No: Issues found" --> AuditRemediation[Remediate:\nRespawn teacher]
        AuditRemediation --> SpawnAuditor
    end

    %% Audit failure escalation - feedback loop (max iterations exceeded)
    AuditCheck -- "No: Escalate" --> PackageAuditContext[Package AUDIT_FAILURE\nContext]
    PackageAuditContext -.->|Re-plan with AUDIT_FAILURE| Phase1

    %% ========================================
    %% SUCCESS PATH
    %% ========================================
    AuditCheck -- "Yes: PASS" --> MarkComplete[Complete all tickets\nvia CLI]
    MarkComplete --> End((End))

    %% ========================================
    %% STYLING
    %% ========================================
    classDef completed fill:#90EE90,stroke:#228B22
    classDef inprogress fill:#FFFF99,stroke:#DAA520
    classDef failed fill:#FFB6C1,stroke:#DC143C
    classDef pending fill:#E8E8E8,stroke:#808080

    linkStyle 10 stroke:#888,stroke-width:2px,stroke-dasharray: 5 5;
