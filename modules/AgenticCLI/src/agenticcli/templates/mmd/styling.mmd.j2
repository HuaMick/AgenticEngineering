    %% ========================================
    %% STYLING
    %% ========================================
    classDef entrypoint fill:#90EE90,stroke:#228B22
    classDef exitpoint fill:#FFB6C1,stroke:#DC143C
    classDef userpoint fill:#87CEEB,stroke:#4682B4
    classDef keyaction fill:#FFD700,stroke:#DAA520
{% if cli_actions %}
    classDef cliaction fill:#FFD700,stroke:#DAA520
{% endif %}
    class Start entrypoint
    class End exitpoint
    class AskUser{% if escalate_nodes %},{{ escalate_nodes | join(',') }}{% else %},EscalateTests{% endif %} userpoint
{% if key_action_nodes %}
    class {{ key_action_nodes | join(',') }} keyaction
{% endif %}
{% if cli_action_nodes %}
    class {{ cli_action_nodes | join(',') }} cliaction
{% endif %}
