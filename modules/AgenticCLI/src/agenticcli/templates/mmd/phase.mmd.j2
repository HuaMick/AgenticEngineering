    %% ========================================
    %% PHASE {{ phase_number }}: {{ phase_name | upper }}
    %% ========================================
    %% AGENT_ROUTING: {{ agent }} agent {{ phase_description }}
    %% Tasks: {{ task_ids }}

    subgraph {{ phase_id }}_SG ["Phase {{ phase_number }}: {{ phase_name }} Subgraph"]
        Phase{{ phase_number }}[Enter Phase {{ phase_number }}: {{ phase_name }}] --> Spawn{{ agent | capitalize }}{{ phase_number }}[Spawn {{ agent }} Agent]
{% for step in steps %}
        {% if loop.first %}Spawn{{ agent | capitalize }}{{ phase_number }}{% else %}{{ steps[loop.index0 - 1].id }}{% endif %} --> {{ step.id }}[{{ step.label }}]
{% endfor %}
        {{ steps[-1].id }} --> Phase{{ phase_number }}Complete[Phase {{ phase_number }} Complete]
    end

{% if next_phase %}
    Phase{{ phase_number }}Complete --> Phase{{ next_phase }}
{% endif %}

