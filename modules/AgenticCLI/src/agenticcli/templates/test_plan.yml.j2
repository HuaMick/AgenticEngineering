# Test Plan - {{ plan_name }}
# Generated: {{ timestamp }}

plan:
  name: "{{ plan_name }}"
  type: test
  status: pending
  created: "{{ date }}"
  worktree: {{ worktree }}
{% if iteration %}
  iteration: {{ iteration }}
{% endif %}

  summary: |
    Test plan for {{ plan_name }}.
    Validates implementation against requirements.

  test_categories:
    - category: unit
      status: pending
      tests:
        - id: "unit.1"
          name: "Core functionality tests"
          status: pending

    - category: integration
      status: pending
      tests:
        - id: "int.1"
          name: "Integration tests"
          status: pending

    - category: validation
      status: pending
      tests:
        - id: "val.1"
          name: "Lint check"
          status: pending
        - id: "val.2"
          name: "Type check"
          status: pending

  success_criteria:
    - "All unit tests pass"
    - "All integration tests pass"
    - "Coverage meets threshold"
    - "No lint errors"
