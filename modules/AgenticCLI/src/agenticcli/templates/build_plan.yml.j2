# Build Plan - {{ plan_name }}
# Generated: {{ timestamp }}

plan:
  name: "{{ plan_name }}"
  type: build
  status: pending
  created: "{{ date }}"
  worktree: {{ worktree }}
  branch: {{ branch }}
{% if iteration %}
  iteration: {{ iteration }}
{% endif %}

  summary: |
    Build plan for {{ plan_name }}.
    Generated from template on {{ date }}.

  phases:
    - id: "01"
      name: "Phase 1: Setup"
      status: pending
      tasks:
        - id: "01.1"
          title: "Initial setup"
          status: pending

    - id: "02"
      name: "Phase 2: Implementation"
      status: pending
      tasks:
        - id: "02.1"
          title: "Core implementation"
          status: pending

    - id: "03"
      name: "Phase 3: Testing"
      status: pending
      tasks:
        - id: "03.1"
          title: "Write tests"
          status: pending
        - id: "03.2"
          title: "Run test suite"
          status: pending

  success_criteria:
    - "All tests pass"
    - "Lint clean"
    - "Documentation updated"
