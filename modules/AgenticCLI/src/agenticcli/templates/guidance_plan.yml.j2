# Guidance Plan - {{ plan_name }}
# Generated: {{ timestamp }}

plan:
  name: "{{ plan_name }}"
  type: guidance
  status: pending
  created: "{{ date }}"
  worktree: {{ worktree }}
{% if iteration %}
  iteration: {{ iteration }}
{% endif %}

  summary: |
    Guidance improvement plan for {{ plan_name }}.
    Focuses on agent paths, signposts, and fences.

  guidance_areas:
    - area: process
      status: pending
      improvements:
        - id: "proc.1"
          name: "Review process.yml"
          status: pending

    - area: inputs
      status: pending
      improvements:
        - id: "inp.1"
          name: "Validate inputs.yml"
          status: pending

    - area: assets
      status: pending
      improvements:
        - id: "asset.1"
          name: "Update shared assets"
          status: pending

  validation:
    - id: "val.1"
      name: "Walkthrough test"
      status: pending
      description: "Simulate agent execution"

    - id: "val.2"
      name: "Friction analysis"
      status: pending
      description: "Identify and remove friction points"

  success_criteria:
    - "All guidance areas reviewed"
    - "Friction points addressed"
    - "Walkthrough test passes"
