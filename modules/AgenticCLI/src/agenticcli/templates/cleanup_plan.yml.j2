# Cleanup Plan - {{ plan_name }}
# Generated: {{ timestamp }}

plan:
  name: "{{ plan_name }}"
  type: cleanup
  status: pending
  created: "{{ date }}"
  worktree: {{ worktree }}
{% if iteration %}
  iteration: {{ iteration }}
{% endif %}

  summary: |
    Cleanup and finalization plan for {{ plan_name }}.
    Prepares implementation for completion.

  cleanup_tasks:
    - id: "clean.1"
      name: "Code review"
      status: pending
      description: "Review all changes for quality"

    - id: "clean.2"
      name: "Documentation"
      status: pending
      description: "Update documentation and comments"

    - id: "clean.3"
      name: "Lint and format"
      status: pending
      description: "Run linter and formatter"

    - id: "clean.4"
      name: "Test coverage"
      status: pending
      description: "Ensure adequate test coverage"

  finalization:
    - id: "final.1"
      name: "Archive planning files"
      status: pending

    - id: "final.2"
      name: "Update changelog"
      status: pending

    - id: "final.3"
      name: "Create release notes"
      status: pending

  success_criteria:
    - "All cleanup tasks complete"
    - "Documentation current"
    - "Ready for merge/release"
