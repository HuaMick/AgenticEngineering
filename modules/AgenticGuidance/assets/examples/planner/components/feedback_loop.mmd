    %% COMPONENT: Feedback Loop
    %% PURPOSE: Generic iterative refinement pattern with feedback capture
    %% USAGE: Embed in any phase requiring iterative improvement based on feedback
    %% REUSABILITY: Works for planning, building, testing, or any review cycle
    %%
    %% PATTERN SUMMARY:
    %% 1. Primary agent performs action
    %% 2. Reviewer/validator provides feedback
    %% 3. Feedback captured and applied
    %% 4. Loop until approved or max iterations
    %%
    %% INPUTS (from embedding phase):
    %% - primary_agent: Agent performing the action
    %% - reviewer_agent: Agent providing feedback
    %% - max_iterations: Loop limit (default: 5)
    %% - success_criteria: What defines "approved"
    %%
    %% EXIT CONDITIONS:
    %% - Success: Reviewer approves result
    %% - Escalate: Max iterations reached without approval

    %% ===== ENTRY =====
    FeedbackLoopStart((Feedback Loop)) --> PerformAction[Primary Agent Performs Action]

    %% ===== ACTION + REVIEW =====
    PerformAction --> RequestReview[Request Review from Reviewer Agent]

    RequestReview --> ReviewResult{Review Result?}

    %% ===== SUCCESS PATH =====
    ReviewResult -- "Approved" --> FeedbackLoopComplete((Loop Complete: Approved))

    %% ===== ITERATION PATH =====
    ReviewResult -- "Needs Refinement" --> CaptureFeedback[Capture Reviewer Feedback
    - Specific issues identified
    - Suggested improvements
    - Priority of changes]

    CaptureFeedback --> CheckIterations{Max Iterations?}

    CheckIterations -- "No: Continue" --> ApplyFeedback[Apply Feedback to Artifact]

    ApplyFeedback --> PerformAction

    CheckIterations -- "Yes: Limit Reached" --> EscalateLoop((Escalate: Max Iterations))

    %% ===== STYLING =====
    classDef entrypoint fill:#90EE90,stroke:#228B22
    classDef exitpoint fill:#FFB6C1,stroke:#DC143C
    classDef feedback fill:#87CEEB,stroke:#4169E1

    class FeedbackLoopStart,FeedbackLoopComplete entrypoint
    class EscalateLoop exitpoint
    class CaptureFeedback,ApplyFeedback feedback
