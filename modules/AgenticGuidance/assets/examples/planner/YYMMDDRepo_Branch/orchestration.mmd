%% - The graph (below) shows phase flow, dependencies, and feedback triggers
%% - classDef styling indicates completed phases

graph TD
    %% ========================================
    %% PHASE FLOW
    %% ========================================
    Start((Start)) --> Phase1[Phase 1: Environment Setup]
    Phase1 --> Phase2[Phase 2: Domain Layer Build]
    Phase2 --> Phase3[Phase 3: Workflow Layer Build]
    Phase3 --> Phase4[Phase 4: Entrypoint Layer Build]
    Phase4 --> Phase5[Phase 5: Integration Testing]
    Phase5 --> Phase6[Phase 6: CI/CD Validation]
    Phase6 --> End((End))

