    %% FEEDBACK TRIGGERS
    %% ========================================
    %% These edges show when phases loop back due to failures.
    %% Dotted lines indicate feedback loops, not normal flow.
    Phase5 -- test_failure --> Phase4
    Phase5 -- test_failure --> Phase3
    Phase5 -- test_failure --> Phase2
    Phase6 -- cicd_failure --> Phase5
    Phase6 -- config_error --> Phase1

    %% ========================================
    %% PHASE DETAILS (Comments)
    %% ========================================
    %% Phase 1: Environment Setup
    %%   - Agent: builder
    %%   - Tasks: Verify dependencies, create branch, setup dev environment
    %%   - Exit: All dependencies installed, branch created
    %%
    %% Phase 2: Domain Layer Build
    %%   - Agent: builder (parallel execution possible)
    %%   - Tasks: Implement domain services, validators, unit tests
    %%   - Exit: Domain layer complete, unit tests pass
    %%
    %% Phase 3: Workflow Layer Build
    %%   - Agent: builder
    %%   - Tasks: Implement workflow orchestration, dependency injection
    %%   - Exit: Workflow layer complete, integration with domain verified
    %%
    %% Phase 4: Entrypoint Layer Build
    %%   - Agent: builder (parallel execution possible - CLI and API)
    %%   - Tasks: Implement CLI commands, API routes
    %%   - Exit: Entrypoints complete, manual smoke tests pass
    %%
    %% Phase 5: Integration Testing
    %%   - Agent: tester
    %%   - Pattern: test-fix-loop (max 5 iterations)
    %%   - Tasks: Run integration tests, fix failures
    %%   - Exit: All integration tests pass
    %%
    %% Phase 6: CI/CD Validation
    %%   - Agent: deployer
    %%   - Tasks: Validate pipeline config, Docker builds, Cloud Build
    %%   - Exit: CI/CD pipeline validates successfully

    %% ========================================
    %% STYLING
    %% ========================================
    %% Completed phases use green styling
    %% In-progress phases use yellow styling
    %% Pending phases use default styling
