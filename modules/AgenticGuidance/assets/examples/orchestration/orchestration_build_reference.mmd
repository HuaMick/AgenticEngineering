%% =================================================================
%% REFERENCE EXAMPLE: Build Orchestration Pattern
%% =================================================================
%% This is a reference implementation showing the original orchestration-build
%% workflow pattern. DO NOT execute directly - use orchestration-executor instead.
%%
%% Originally from: modules/AgenticGuidance/agents/orchestration/orchestration-build/process.mmd
%% Converted to reference: 2026-01-11
%%
%% This pattern shows:
%% - Planning delegation to orchestration-planning
%% - Implementation phase with build agents (build-python, build-flutter)
%% - Test-fix loop for implementation validation
%% - CI/CD validation phase
%% - Guidance validation phase
%% - Final audit phase
%%
%% AGENT_ROUTING METADATA:
%% - agent_type: orchestration-build (deprecated - use orchestration-executor)
%% - delegates_to: orchestration-planning, build-python, build-flutter, test-runner
%% - validates_with: deploy-cicd, test-guidance-simulator, test-final-output
%% - feedback_loops: TEST_FAILURE, CICD_FAILURE, GUIDANCE_GAP, AUDIT_FAILURE
%% =================================================================

flowchart LR
    %% GOAL: Orchestrate agents to implement code changes, features, or bug fixes.
    %% PROFILE: Orchestration-Builder
    %% OUTPUT: Implemented code, tests, and completed epics in docs/epics/completed/
    %% GUIDELINE: BUILD FOCUS policy - code implementation and testing, not guidance-only changes.
    %% GUIDELINE: Every test failure, CI/CD failure, or audit failure MUST trigger re-planning via orchestration-planning.
    %% GUIDELINE: Planning is delegated to orchestration-planning agent OR uses pre-approved plan (approved_plan_path).
    %% GUIDELINE: modules/AgenticGuidance/assets/guidelines/testing.yml - Testing strategies and validation
    %%
    %% AGENT_ROUTING: This is a REFERENCE pattern - actual routing handled by orchestration-executor

    Start((Start)) --> LoadInputs[Load Context Inputs]

    %% Input Verification & Search Logic: Ensure we have all necessary context from inputs.yml
    LoadInputs --> ReviewInputs[Review All Listed Inputs]
    ReviewInputs --> CheckInputs{All Inputs Found?}

    %% If inputs are missing, attempt to self-heal by searching
    CheckInputs -- "No: Missing" --> SearchInputs[Search for Missing Inputs]
    SearchInputs --> Found{Found?}

    %% If found elsewhere, update paths to maintain continuity
    Found -- "Yes: Update paths" --> UpdateRefs[Update References & Flag]
    UpdateRefs --> ReviewInputs

    %% Critical failure: Stop and ask user if context cannot be resolved
    Found -- "No: Stop" --> AskUser((Ask User for Clarification))

    %% Proceed only when context is fully loaded and verified
    CheckInputs -- "Yes: Verified" --> SpawnDeployWorktree[Spawn deploy-worktree Agent]

    %% AGENT_ROUTING: deploy-worktree handles CLI commands for worktree setup
    SpawnDeployWorktree --> VerifyWorktree[Verify Worktree via CLI: agentic worktree status]
    VerifyWorktree --> ValidateEpicFolder[Validate Epic Folder via CLI: agentic epic validate]
    ValidateEpicFolder --> WorktreeValid{Worktree & Epic Valid?}
    WorktreeValid -- "No: Failed verification" --> AskUser

    %% ========================================
    %% PLANNING DELEGATION SUBGRAPH
    %% ========================================
    %% AGENT_ROUTING: Delegates to orchestration-planning for plan creation/approval
    %% INPUT MODES:
    %% 1. approved_plan_path provided: Load and validate pre-approved plan, skip delegation
    %% 2. planning_objective provided: Spawn orchestration-planning to create & approve plan
    %%
    %% FEEDBACK LOOP ENTRY POINTS:
    %% When downstream validation fails, re-invoke orchestration-planning with failure context:
    %% 1. Test Failures: Re-plan with TEST_FAILURE context
    %% 2. CI/CD Failures: Re-plan with CICD_FAILURE context
    %% 3. Guidance Gaps: Re-plan with GUIDANCE_GAP context
    %% 4. Audit Failures: Re-plan with AUDIT_FAILURE context

    WorktreeValid -- "Yes: Verified" --> CheckPlanInput{Pre-approved Plan Provided?}

    subgraph PlanningDelegation ["Planning Delegation Subgraph"]
        %% PATH 1: LOAD PRE-APPROVED PLAN
        CheckPlanInput -- "Yes: Path Provided" --> LoadApprovedPlan[Load Approved Plan from Path]
        LoadApprovedPlan --> ValidatePlan{Plan Valid & Complete?}
        ValidatePlan -- "No: Invalid/Incomplete" --> AskUserPlan((Ask User for Valid Plan))

        %% PATH 2: DELEGATE TO ORCHESTRATION-PLANNING
        %% AGENT_ROUTING: orchestration-planning agent handles full planning workflow
        CheckPlanInput -- "No: Need Planning" --> DelegatePlanning[Spawn orchestration-planning Agent]
        DelegatePlanning --> AwaitPlanApproval[Await orchestration-planning Completion]
        AwaitPlanApproval --> PlanningComplete{Planning Approved?}
        PlanningComplete -- "No: User Rejected" --> AskUserPlan

        %% CONVERGENCE: PLAN READY FOR EXECUTION
        ValidatePlan -- "Yes: Valid" --> PlanReady[Plan Ready for Execution]
        PlanningComplete -- "Yes: Approved" --> PlanReady
    end

    %% ========================================
    %% IMPLEMENTATION PHASE: Build Agents Execute Plan
    %% ========================================
    %% AGENT_ROUTING: Spawns build-python, build-flutter, test-runner agents
    %% LOOP_DEFINITION: modules/AgenticGuidance/assets/definitions/agent-loops.yml#loop_types.test-fix-loop
    %% MAX_ITERATIONS: 5 (per test-fix-loop definition)
    PlanReady --> ExecutePhases[Execute Implementation Phases]

    subgraph Implementation ["Implementation Loop Subgraph"]
        %% AGENT_ROUTING: build-python handles Python implementation
        %% AGENT_ROUTING: build-flutter handles Flutter/Dart implementation
        %% AGENT_ROUTING: test-runner executes tests after implementation
        ExecutePhases --> SpawnBuilders[Spawn build-python/flutter agents]
        SpawnBuilders --> RunTests[Spawn test-runner]
        RunTests --> TestsPassed{Tests Passed?}
        TestsPassed -- "No: Fix in Iteration" --> SpawnBuilders
    end

    %% Test failure escalation path - feeds back to planning
    TestsPassed -- "No: Escalate" --> CategorizeTestFailure[Categorize Test Failure]
    CategorizeTestFailure --> UpdatePlanTests[Package TEST_FAILURE Context]
    UpdatePlanTests -.->|Re-plan with TEST_FAILURE| DelegatePlanning

    %% ========================================
    %% CI/CD VALIDATION PHASE
    %% ========================================
    %% AGENT_ROUTING: deploy-cicd agent audits pipeline changes
    TestsPassed -- "Yes: Passed" --> CICDCheck{CI/CD Changes?}
    CICDCheck -- "Yes" --> SpawnDeploy[Spawn deploy-cicd Audit]
    SpawnDeploy --> CICDValid{CI/CD Valid?}

    CICDValid -- "No: Categorize" --> CategorizeCICDFailure[Categorize CI/CD Failure]
    CategorizeCICDFailure --> UpdatePlanCICD[Package CICD_FAILURE Context]
    UpdatePlanCICD -.->|Re-plan with CICD_FAILURE| DelegatePlanning

    %% ========================================
    %% GUIDANCE VALIDATION PHASE
    %% ========================================
    %% AGENT_ROUTING: planner-guidance-testing and test-guidance-simulator agents
    %% LOOP_DEFINITION: modules/AgenticGuidance/assets/definitions/agent-loops.yml#loop_types.guidance-test-loop
    CICDCheck -- "No" --> GuidanceChanges{Guidance Changes?}
    CICDValid -- "Yes: Valid" --> GuidanceChanges
    GuidanceChanges -- "Yes" --> GuidanceTest[Spawn planner-guidance-testing]
    GuidanceTest --> GuidanceSimulator[Spawn test-guidance-simulator]

    GuidanceSimulator --> UpdateGuidanceStatuses[Update Plan Task Statuses from Test Results]
    UpdateGuidanceStatuses --> GuidancePassed{Guidance Valid?}

    %% GUIDANCE REPAIR LOOP: Failing walkthrough tests trigger re-planning
    GuidancePassed -- "No: Gaps Found" --> CategorizeGuidanceGaps[Categorize Friction Points]
    CategorizeGuidanceGaps --> RouteToHandler{Route by Gap Type}
    RouteToHandler -- "Build Process" --> UpdatePlanBuild[Package GUIDANCE_GAP Context - Build]
    RouteToHandler -- "Test Design" --> UpdatePlanTest[Package GUIDANCE_GAP Context - Test]
    RouteToHandler -- "Guidance" --> UpdatePlanGuidance[Package GUIDANCE_GAP Context - Guidance]
    UpdatePlanBuild -.->|Re-plan with GUIDANCE_GAP| DelegatePlanning
    UpdatePlanTest -.->|Re-plan with GUIDANCE_GAP| DelegatePlanning
    UpdatePlanGuidance -.->|Re-plan with GUIDANCE_GAP| DelegatePlanning

    %% ========================================
    %% FINAL AUDIT PHASE
    %% ========================================
    %% AGENT_ROUTING: test-final-output agent performs final validation
    GuidanceChanges -- "No" --> SpawnFinalAudit[Spawn test-final-output Audit]
    GuidancePassed -- "Yes: Verified" --> SpawnFinalAudit

    SpawnFinalAudit --> FinalAudit{Final Audit Passed?}

    FinalAudit -- "No: Failed" --> UpdatePlanAudit[Package AUDIT_FAILURE Context]
    UpdatePlanAudit -.->|Re-plan with AUDIT_FAILURE| DelegatePlanning

    %% ========================================
    %% FINALIZATION
    %% ========================================
    FinalAudit -- "Yes: Verified" --> MoveCompletedTasks[Move Completed Tickets via CLI: agentic epic move tickets]
    MoveCompletedTasks --> ArchiveEpicFolder[Archive Epic Folder via CLI: agentic epic move folder]
    ArchiveEpicFolder --> End((End))

    %% Styling for feedback loops (return paths to DelegatePlanning)
    classDef dashedstroke stroke-dasharray: 5 5;
    linkStyle 29,35,47,48,49,54 stroke:#888,stroke-width:2px,stroke-dasharray: 5 5;
