flowchart LR
    %% ========================================
    %% UAT PHASE COMPONENT
    %% ========================================
    %% GOAL: Validate user acceptance through story-based testing with flexible strategy selection.
    %% PROFILE: Planner-Component-UAT
    %% COMPONENT_TYPE: Reusable phase component for orchestration plans
    %% USAGE: MANDATORY for all plans - implementation strategy at planner's discretion.
    %%
    %% LOOP_DEFINITION: modules/AgenticGuidance/assets/definitions/agent-loops.yml#loop_types.user-story-validation-loop
    %% MAX_ITERATIONS: 3 (per user-story-validation-loop definition)
    %% ESCALATION: If max iterations reached without all stories passing, stop and Ask User
    %%
    %% FENCE: UAT MUST be anchored to user stories - no UAT without defined stories.
    %%
    %% INPUTS (expected from orchestrator):
    %% - user_stories: Defined user stories with acceptance criteria
    %% - implementation_artifacts: Built features to validate
    %% - strategy_preference: Optional preferred UAT strategy
    %%
    %% EXIT CONDITIONS:
    %% - Success: All user stories pass validation
    %% - Escalate: Max iterations reached or no user stories defined
    %%
    %% STRATEGY OPTIONS:
    %% - simulator: test-user-simulator executes journeys
    %% - blind_test: test-guidance-simulator without prior context
    %% - doc_loop: Documentation-based user validation
    %% - manual: Human validator executes stories

    %% ========================================
    %% ENTRY POINT (MANDATORY)
    %% ========================================
    %% UAT is MANDATORY for all plans. Entry validates user stories exist.
    UATPhaseStart((UAT Phase)) --> ValidateUserStories[Validate User Stories Exist]

    %% ========================================
    %% USER STORY FENCE
    %% ========================================
    %% FENCE: UAT MUST be anchored to user stories.
    %% Plans without defined user stories cannot proceed with UAT.
    ValidateUserStories --> StoriesExist{User Stories Defined?}
    StoriesExist -- "No: Missing Stories" --> EscalateUAT((Escalate: No User Stories))
    StoriesExist -- "Yes: Stories Found" --> SelectStrategy[Select UAT Strategy]

    %% ========================================
    %% STRATEGY SELECTION
    %% ========================================
    %% Planner selects appropriate strategy based on context.
    %% All strategies ultimately validate the same user stories.
    subgraph StrategySelection_SG ["UAT Strategy Options Subgraph"]
        SelectStrategy --> StrategyChoice{Which Strategy?}

        %% Option 1: User Simulator (Automated)
        %% Uses test-user-simulator to execute simulated user journeys.
        %% Best for: Repeatable automated validation of user flows.
        StrategyChoice -- "Simulator" --> SimulatorPath[Spawn test-user-simulator]
        SimulatorPath --> SimulatorExecute[Execute Simulated User Journeys]
        SimulatorExecute --> SimulatorResults[Collect Simulation Results]

        %% Option 2: Blind Test (Guidance Validation)
        %% Uses test-guidance-simulator without prior context.
        %% Best for: Validating documentation completeness alongside UAT.
        StrategyChoice -- "Blind Test" --> BlindTestPath[Spawn test-guidance-simulator]
        BlindTestPath --> BlindTestExecute[Execute Without Prior Context]
        BlindTestExecute --> BlindTestResults[Collect Blind Test Results]

        %% Option 3: Documentation Loop (User Documentation)
        %% Creates user documentation, user reviews and validates.
        %% Best for: End-user facing features needing docs validation.
        StrategyChoice -- "Doc Loop" --> DocLoopPath[Create User Documentation]
        DocLoopPath --> DocLoopReview[User Reviews Documentation]
        DocLoopReview --> DocLoopResults[Collect Documentation Feedback]

        %% Option 4: Manual Validation (Human UAT)
        %% Human validator executes user stories manually.
        %% Best for: Complex scenarios requiring human judgment.
        StrategyChoice -- "Manual" --> ManualPath[Present to Human Validator]
        ManualPath --> ManualExecute[Human Executes User Stories]
        ManualExecute --> ManualResults[Collect Human Feedback]
    end

    %% ========================================
    %% RESULTS AGGREGATION
    %% ========================================
    %% All strategies feed into unified result evaluation.
    SimulatorResults --> AggregateResults[Aggregate UAT Results]
    BlindTestResults --> AggregateResults
    DocLoopResults --> AggregateResults
    ManualResults --> AggregateResults

    %% ========================================
    %% EVALUATION AND ITERATION
    %% ========================================
    %% Evaluate results against user story acceptance criteria.
    AggregateResults --> EvaluateResults{All Stories Pass?}

    %% Failure triggers iteration or escalation
    subgraph UATIteration_SG ["UAT Iteration Subgraph"]
        EvaluateResults -- "No: Failures" --> CaptureFailures[Capture Story Failures]
        CaptureFailures --> CanIterate{Iteration Possible?}
        CanIterate -- "Yes: Retry" --> SelectStrategy
        CanIterate -- "No: Max Reached" --> EscalateUAT
    end

    %% Success completes UAT phase
    EvaluateResults -- "Yes: All Pass" --> UATPhaseComplete((UAT Phase Complete))

    %% ========================================
    %% STYLING
    %% ========================================
    classDef entrypoint fill:#90EE90,stroke:#228B22
    classDef exitpoint fill:#FFB6C1,stroke:#DC143C
    classDef mandatory fill:#FFD700,stroke:#B8860B
    classDef dashedstroke stroke-dasharray: 5 5
    class UATPhaseStart,UATPhaseComplete entrypoint
    class EscalateUAT exitpoint
    class ValidateUserStories mandatory
    %% Dashed line for iteration feedback
    linkStyle 17 stroke:#888,stroke-width:2px,stroke-dasharray: 5 5
