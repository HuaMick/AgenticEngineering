flowchart LR
    %% ========================================
    %% TEACH PHASE COMPONENT
    %% ========================================
    %% GOAL: Plan and execute guidance improvement through planner-guidance + reviewer loop.
    %% PROFILE: Planner-Component-Teach
    %% COMPONENT_TYPE: Reusable phase component for orchestration plans
    %% USAGE: Planners incorporate this pattern when guidance improvement is required.
    %%
    %% LOOP_DEFINITION: modules/AgenticGuidance/assets/definitions/agent-loops.yml#loop_types.planner-loop
    %% MAX_ITERATIONS: 5 (per planner-loop definition)
    %% ESCALATION: If max iterations reached without approval, stop and Ask User
    %%
    %% INPUTS (expected from orchestrator):
    %% - friction_source: Location or description of identified friction
    %% - target_agent: Agent(s) whose guidance needs improvement
    %% - target_project_path: Project root for context
    %%
    %% EXIT CONDITIONS:
    %% - Success: Plan approved by reviewer, ready for teacher execution
    %% - Escalate: Max iterations reached or cannot create plan

    %% ========================================
    %% ENTRY POINT
    %% ========================================
    %% Assumes phase determination has identified teaching/guidance as needed.
    TeachPhaseStart((Teach Phase)) --> SpawnPlannerGuidance[Spawn planner-guidance Agent]

    %% ========================================
    %% PLANNER-LOOP: PLAN CREATION
    %% ========================================
    %% planner-guidance creates teaching plan based on friction analysis.
    %% Plan includes: target files, tasks with acceptance criteria, test scenarios.
    SpawnPlannerGuidance --> PlanCreated{Plan Created?}

    PlanCreated -- "No: Error" --> EscalateTeach((Escalate: Cannot Create Plan))
    PlanCreated -- "Yes" --> SpawnReviewer[Spawn planner-reviewer Agent]

    %% ========================================
    %% PLANNER-LOOP: REVIEW ITERATION
    %% ========================================
    %% REVIEWER CRITERIA:
    %% - Task specificity (concrete file paths, acceptance criteria)
    %% - Alignment with friction source
    %% - Test scenario coverage
    SpawnReviewer --> ReviewResult{Plan Approved?}

    %% Iterative refinement loop
    subgraph PlannerLoop_SG ["Planner-Loop Subgraph"]
        ReviewResult -- "No: Refine" --> CaptureFeedback[Capture Reviewer Feedback]
        CaptureFeedback --> CheckIterations{Max Iterations?}
        CheckIterations -- "No: Continue" --> SpawnPlannerGuidanceFix[Spawn planner-guidance Agent]
        SpawnPlannerGuidanceFix --> SpawnReviewer
        CheckIterations -- "Yes: Limit Reached" --> EscalateTeach
    end

    %% Approved plan exits to next phase
    ReviewResult -- "Yes: Approved" --> TeachPhaseComplete((Teach Phase Complete))

    %% ========================================
    %% STYLING
    %% ========================================
    classDef entrypoint fill:#90EE90,stroke:#228B22
    classDef exitpoint fill:#FFB6C1,stroke:#DC143C
    classDef dashedstroke stroke-dasharray: 5 5
    class TeachPhaseStart,TeachPhaseComplete entrypoint
    class EscalateTeach exitpoint
