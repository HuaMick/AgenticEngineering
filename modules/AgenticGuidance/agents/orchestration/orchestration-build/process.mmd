%% =============================================================================
%% CCI BOOTSTRAP (CLI Context Injection) - EXECUTE FIRST
%% =============================================================================
%% Before following this flowchart, run:
%%   agentic context bootstrap --role orchestration-build -j
%%   agentic plan task current -j
%%
%% This provides structured context more efficiently than file exploration.
%% =============================================================================

flowchart LR
    %% GOAL: Orchestrate agents to implement code changes, features, or bug fixes.
    %% PROFILE: Orchestration-Builder
    %% OUTPUT: Implemented code, tests, and completed plans in docs/plans/completed/
    %% GUIDELINE: BUILD FOCUS policy - code implementation and testing, not guidance-only changes.
    %% GUIDELINE: Every test failure, CI/CD failure, or audit failure MUST trigger re-planning via orchestration-planning.
    %% GUIDELINE: Planning is delegated to orchestration-planning agent OR uses pre-approved plan (approved_plan_path).
    %% GUIDELINE: modules/AgenticGuidance/assets/guidelines/testing.yml - Testing strategies and validation
    %% INPUT_PATH: modules/AgenticGuidance/agents/orchestration/orchestration-build/inputs.yml

    Start((Start)) --> LoadInputs[Load Context Inputs]

    %% Input Verification & Search Logic: Ensure we have all necessary context from inputs.yml
    LoadInputs --> ReviewInputs[Review All Listed Inputs]
    ReviewInputs --> CheckInputs{All Inputs Found?}

    %% If inputs are missing, attempt to self-heal by searching
    CheckInputs -- "No: Missing" --> SearchInputs[Search for Missing Inputs]
    SearchInputs --> Found{Found?}

    %% If found elsewhere, update paths to maintain continuity
    Found -- "Yes: Update paths" --> UpdateRefs[Update References & Flag]
    UpdateRefs --> ReviewInputs

    %% Critical failure: Stop and ask user if context cannot be resolved
    Found -- "No: Stop" --> AskUser((Ask User for Clarification))

    %% Proceed only when context is fully loaded and verified
    CheckInputs -- "Yes: Verified" --> CheckExistingPlan{Pre-approved Plan Exists?}

    %% WORKTREE & PLAN FOLDER SETUP - CLI: agentic plan init/validate
    CheckExistingPlan -- "Yes: Has Plan Path" --> ValidatePlanFolder[Validate Plan Folder via CLI: agentic plan validate]
    CheckExistingPlan -- "No: Needs Init" --> InitPlanFolder[Run CLI: agentic plan init branch --description desc]
    InitPlanFolder --> CheckInitResult{CLI Exit Code 0?}
    CheckInitResult -- "No: Exit 1/2/3" --> AskUser((Ask User for Clarification))
    CheckInitResult -- "Yes: Success" --> ValidatePlanFolder
    ValidatePlanFolder --> WorktreeValid{Plan Folder Valid?}
    WorktreeValid -- "No: Failed verification" --> AskUser

    %% PLANNING DELEGATION: Uses approved_plan_path OR spawns orchestration-planning
    %% Failure contexts (TEST_FAILURE, CICD_FAILURE, GUIDANCE_GAP, AUDIT_FAILURE, UAT_FAILURE) trigger re-planning

    WorktreeValid -- "Yes: Verified" --> CheckPlanInput{Pre-approved Plan Provided?}

    subgraph PlanningDelegation ["Planning Delegation Subgraph"]
        %% ----------------------------------------
        %% PATH 1: LOAD PRE-APPROVED PLAN
        %% ----------------------------------------
        %% When approved_plan_path is provided, load and validate it.
        %% Validation ensures all required files exist with status: approved.
        CheckPlanInput -- "Yes: Path Provided" --> LoadApprovedPlan[Load Approved Plan from Path]
        LoadApprovedPlan --> ValidatePlan{Plan Valid & Complete?}

        %% If plan validation fails, ask user for clarification
        ValidatePlan -- "No: Invalid/Incomplete" --> AskUserPlan((Ask User for Valid Plan))

        %% ----------------------------------------
        %% PATH 2: DELEGATE TO ORCHESTRATION-PLANNING
        %% ----------------------------------------
        %% When no approved plan, spawn orchestration-planning with objective.
        %% orchestration-planning handles: exploration synthesis, planner-build,
        %% planner-test, planner-reviewer loops, and human approval gate.
        %%
        %% FAILURE CONTEXT HANDLING:
        %% When failure_context is provided (from downstream failures):
        %% - Pass failure_type, failure_details, original_plan_path, iteration_count
        %% - orchestration-planning incorporates feedback into updated plan
        CheckPlanInput -- "No: Need Planning" --> DelegatePlanning[Spawn orchestration-planning Agent]

        %% orchestration-planning runs its complete planning workflow:
        %% - Build Planning Loop (planner-build + planner-reviewer)
        %% - Test Planning Loop (planner-test + planner-reviewer)
        %% - Human approval gate
        DelegatePlanning --> AwaitPlanApproval[Await orchestration-planning Completion]
        AwaitPlanApproval --> PlanningComplete{Planning Approved?}

        %% If user rejects plan in orchestration-planning, escalate
        PlanningComplete -- "No: User Rejected" --> AskUserPlan

        %% ----------------------------------------
        %% CONVERGENCE: PLAN READY FOR EXECUTION
        %% ----------------------------------------
        %% Both paths converge here with approved plans ready for execution.
        ValidatePlan -- "Yes: Valid" --> PlanReady[Plan Ready for Execution]
        PlanningComplete -- "Yes: Approved" --> PlanReady
    end

    %% NOTE: Approved plan drives test execution in Implementation Phase
    %% plan_live_test.yml defines which tests will validate the build

    %% IMPLEMENTATION PHASE - test-fix-loop, max 5 iterations
    PlanReady --> ExecutePhases[Execute Implementation Phases]

    subgraph Implementation ["Implementation Loop Subgraph"]
        %% Build agents (build-python, build-flutter) + test-runner
        ExecutePhases --> SpawnBuilders[Spawn build-python/flutter agents]
        SpawnBuilders --> RunTests[Spawn test-runner]
        RunTests --> TestsPassed{Tests Passed?}
        TestsPassed -- "No: Fix in Iteration" --> SpawnBuilders
    end

    %% Test failure escalation path for severe issues
    %% Re-invoke orchestration-planning with TEST_FAILURE context
    TestsPassed -- "No: Escalate" --> CategorizeTestFailure[Categorize Test Failure]
    CategorizeTestFailure --> UpdatePlanTests[Package TEST_FAILURE Context]
    UpdatePlanTests -.->|Re-plan with TEST_FAILURE| DelegatePlanning

    %% CI/CD VALIDATION PHASE - deploy-cicd audits pipeline changes
    TestsPassed -- "Yes: Passed" --> CICDCheck{CI/CD Changes?}
    CICDCheck -- "Yes" --> SpawnDeploy[Spawn deploy-cicd Audit]
    SpawnDeploy --> CICDValid{CI/CD Valid?}

    %% CI/CD failure categorization
    %% Re-invoke orchestration-planning with CICD_FAILURE context
    CICDValid -- "No: Categorize" --> CategorizeCICDFailure[Categorize CI/CD Failure]
    CategorizeCICDFailure --> UpdatePlanCICD[Package CICD_FAILURE Context]
    UpdatePlanCICD -.->|Re-plan with CICD_FAILURE| DelegatePlanning

    %% GUIDANCE VALIDATION PHASE - guidance-test-loop, max 3 iterations
    CICDCheck -- "No" --> GuidanceChanges{Guidance Changes?}
    CICDValid -- "Yes: Valid" --> GuidanceChanges
    GuidanceChanges -- "Yes" --> GuidanceTest[Spawn planner-guidance-testing]
    GuidanceTest --> GuidanceSimulator[Spawn test-guidance-simulator]

    %% Update plan task statuses from test results
    GuidanceSimulator --> UpdateGuidanceStatuses[Update Plan Task Statuses from Test Results]
    UpdateGuidanceStatuses --> GuidancePassed{Guidance Valid?}

    %% GUIDANCE REPAIR LOOP: Route friction points by gap type, re-plan with GUIDANCE_GAP context
    GuidancePassed -- "No: Gaps Found" --> CategorizeGuidanceGaps[Categorize Friction Points]
    CategorizeGuidanceGaps --> RouteToHandler{Route by Gap Type}
    RouteToHandler -- "Build Process" --> UpdatePlanBuild[Package GUIDANCE_GAP Context - Build]
    RouteToHandler -- "Test Design" --> UpdatePlanTest[Package GUIDANCE_GAP Context - Test]
    RouteToHandler -- "Guidance" --> UpdatePlanGuidance[Package GUIDANCE_GAP Context - Guidance]
    UpdatePlanBuild -.->|Re-plan with GUIDANCE_GAP| DelegatePlanning
    UpdatePlanTest -.->|Re-plan with GUIDANCE_GAP| DelegatePlanning
    UpdatePlanGuidance -.->|Re-plan with GUIDANCE_GAP| DelegatePlanning

    %% FINAL AUDIT PHASE
    GuidanceChanges -- "No" --> SpawnFinalAudit[Spawn test-final-output Audit]
    GuidancePassed -- "Yes: Verified" --> SpawnFinalAudit

    SpawnFinalAudit --> FinalAudit{Final Audit Passed?}

    %% If audit fails, re-invoke orchestration-planning with AUDIT_FAILURE context
    FinalAudit -- "No: Failed" --> UpdatePlanAudit[Package AUDIT_FAILURE Context]
    UpdatePlanAudit -.->|Re-plan with AUDIT_FAILURE| DelegatePlanning

    %% UAT VALIDATION PHASE (MANDATORY) - max 3 iterations, then escalate
    FinalAudit -- "Yes: Verified" --> CheckUATStories{User Stories Exist?}

    subgraph UAT_SG ["UAT Validation Subgraph"]
        %% If no stories exist, spawn planner-test to create them
        CheckUATStories -- "No" --> CreateUATStories[Spawn planner-test for UAT Stories]
        CreateUATStories --> StoryCreationResult{Stories Created?}
        StoryCreationResult -- "Yes" --> CheckUATStories
        StoryCreationResult -- "No: Failed" --> EscalateNoStories((Escalate: Cannot Create UAT Stories))

        %% Execute UAT with stories
        CheckUATStories -- "Yes" --> EnterUATPhase[Enter UAT Validation Phase]
        EnterUATPhase --> SpawnUserSimulator[Spawn test-user-simulator Agent]
        SpawnUserSimulator --> ExecuteStories[Execute User Story Tests]
        ExecuteStories --> UATResults{All Stories Pass?}

        %% UAT failure triggers re-planning with UAT_FAILURE context
        %% Iteration check prevents infinite retry loop
        UATResults -- "No: Failures" --> CheckUATIterations{Max UAT Iterations (3)?}
        CheckUATIterations -- "No: Retry" --> PackageUATFailure[Package UAT_FAILURE Context]
        PackageUATFailure -.->|Re-plan with UAT_FAILURE| DelegatePlanning
        CheckUATIterations -- "Yes: Max Reached" --> EscalateUAT((Escalate: UAT Max Iterations))

        UATResults -- "Yes: All Pass" --> UATComplete[UAT Validation Complete]
    end

    %% FINALIZATION - CLI: agentic plan move tasks/folder
    UATComplete --> MoveCompletedTasks[Move Completed Tasks via CLI: agentic plan move tasks]
    MoveCompletedTasks --> ArchivePlanFolder[Archive Plan Folder via CLI: agentic plan move folder]
    ArchivePlanFolder --> End((End))

    %% Styling for feedback loops (dotted lines for re-planning paths)
    classDef dashedstroke stroke-dasharray: 5 5;
    linkStyle 33,39,51,52,53,58,70 stroke:#888,stroke-width:2px,stroke-dasharray: 5 5;
