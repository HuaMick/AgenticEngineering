%% =============================================================================
%% CCI BOOTSTRAP (CLI Context Injection) - EXECUTE FIRST
%% =============================================================================
%% Before following this flowchart, run:
%%   agentic context bootstrap --role orchestration-planning -j
%%   agentic plan task current -j
%%
%% This provides structured context more efficiently than file exploration.
%%
%% PRINCIPLE: CLI-FIRST CONTEXT
%% Always use agentic CLI commands for initial context. Agents should not
%% need Read/Glob/Grep tools during bootstrap phase. All context retrieval
%% should flow through CCI commands before any file exploration.
%% =============================================================================
%%
%% CLI SESSION/LOOP COMMANDS (for executor handoff):
%% When plans require iterative workflows, specify CLI loop commands:
%%   agentic loop start --prompt <text> --max-iterations <n> --dangerously-skip-permissions -j
%%   agentic loop start --entrypoint <name> --completion-promise <text> -b
%%   agentic loop status <loop-id> -j
%%   agentic loop history --active -j
%%
%% When spawning parallel sessions is needed:
%%   agentic session spawn --prompt <p> --dangerously-skip-permissions -j
%%   agentic session list -j
%%   agentic session status <session-id> -j
%%
%% MANDATE: Reference CLI commands in generated orchestration MMDs for executor.
%%
%% CLI TASK MANAGEMENT MANDATE:
%%   - NEVER use Edit tool to change task status in plan YAML files
%%   - ALWAYS use `agentic plan task start/complete <task_id>` for status updates
%%   - ALWAYS use `agentic plan move folder --plan <plan_folder>` for archiving
%% =============================================================================

flowchart LR
    %% GOAL: Orchestrate planning agents to create executable plans without execution.
    %% PROFILE: Orchestration-Planning
    %% GUIDELINE: PLANNING ONLY policy - no execution, no exploration loops.
    %% GUIDELINE: User provides all necessary context in their prompt - no discovery phase.
    %% GUIDELINE: modules/AgenticGuidance/assets/definitions/plans.yml - Plan types and folder structure
    %% GUIDELINE: Main-First Planning - plans are created in the MAIN worktree for visibility
    %%   Reference: modules/AgenticGuidance/assets/guidelines/worktree-and-branching.yml#Main-First Planning
    %% GUIDELINE: ORCHESTRATION-LOOP-OWNERSHIP
    %% - Orchestrators OWN loop strategy selection (which loop, when to use)
    %% - Planners REQUEST validation needs (e.g., "needs test-fix iteration")
    %% - Planners do NOT dictate specific loop structures in their plans
    %% - Loop definitions: modules/AgenticGuidance/assets/definitions/agent-loops.yml
    %% GUIDELINE: CLI Error Recovery - modules/AgenticGuidance/assets/guidelines/cli-error-recovery.yml
    %% FENCE: If ANY agentic command fails, follow DOGFOOD RULE immediately. Do NOT continue planning.
    %% INPUT_PATH: modules/AgenticGuidance/agents/orchestration/orchestration-planning/inputs.yml
    %%
    %% ENTRYPOINT AWARENESS:
    %% This orchestrator is invoked via entrypoints that signal planning intent:
    %% - _plan_build.yml: Build/implementation planning (prioritize planner-build)
    %% - _plan_teach.yml: Teaching/guidance planning (prioritize planner-guidance)
    %% - _plan_test.yml: Test strategy planning (prioritize planner-test)
    %% The entrypoint intent influences phase determination and planner selection order.
    %%
    %% MMD GENERATION DELEGATION:
    %% After all phase plans are approved, this orchestrator spawns planner-orchestration
    %% to generate the orchestration MMD file. Individual planners create plan YAML only.
    %% HANDOVER MODEL: Planner (YAML) -> planner-orchestration (generates MMD) -> Reviewer (validates package)
    %%
    %% OUTPUTS (FENCE: Output must match declared schema before marking complete):
    %% - Plan folder: docs/plans/live/{plan_id}/ with required structure
    %% - README.md: Plan overview and folder structure
    %% - plan_*.yml: Phase plan files (build, test, teach, cleanup as needed)
    %% - orchestration_<name>.mmd: Orchestration flowchart for executor (generated by planner-orchestration)
    %% - Each plan file requires: name, status, phases fields
    %% - MMD schema reference: modules/AgenticGuidance/assets/specifications/plan-mmd-schema.yml
    %% - Plan schema reference: modules/AgenticGuidance/assets/examples/planner/YYMMDDXX_description/live/plan_example.yml

    Start((Start)) --> LoadInputs[Load Context Inputs]

    %% ========================================
    %% INPUT VALIDATION PHASE
    %% ========================================
    %% Verify all required context is provided in the user prompt.
    %% Unlike orchestration-build, NO exploration phase - user supplies context.
    LoadInputs --> ReviewInputs[Review All Listed Inputs]
    ReviewInputs --> CheckInputs{All Inputs Found?}

    %% If inputs are missing, ask user for clarification (no self-healing search)
    CheckInputs -- "No: Missing" --> AskUser((Ask User for Clarification))

    %% Proceed when context is verified
    CheckInputs -- "Yes: Verified" --> InitPlanFolder[Run CLI: agentic plan init branch --description desc]

    %% ========================================
    %% WORKTREE & PLAN FOLDER SETUP
    %% ========================================
    %% MAIN-FIRST PLANNING: Plan folders are created in the MAIN worktree.
    %% This ensures all plans are visible from a single location before execution.
    %% Execution happens in feature worktrees AFTER plan approval.
    %%
    %% CLI OFFLOAD: Use 'agentic plan init' for combined worktree + plan folder creation.
    %% This single CLI command (run in MAIN worktree):
    %% - Creates worktree if needed (or reuses existing)
    %% - Enforces YYMMDDXX_description naming convention programmatically
    %% - Creates plan folder with flat structure (plan files at root, no subdirectories)
    %% - Returns exit codes: 0=success, 1=worktree failed, 2=folder exists, 3=invalid input
    %% For JSON output: agentic -j plan init <branch> --description <desc>
    %%
    %% NOTE: No agent spawning needed - CLI handles the operation deterministically.
    %% This eliminates naming convention drift from agent interpretation.
    InitPlanFolder --> CheckInitResult{CLI Exit Code 0?}
    CheckInitResult -- "No: Exit 1" --> AskUser((Worktree Creation Failed - Ask User))
    CheckInitResult -- "No: Exit 2" --> AskUser((Folder Already Exists - Ask User for New Description))
    CheckInitResult -- "No: Exit 3" --> AskUser((Invalid Input - Ask User))
    CheckInitResult -- "Yes: Success" --> ValidatePlanFolder[Validate Plan Folder via CLI: agentic plan validate]
    ValidatePlanFolder --> WorktreeValid{Plan Folder Valid?}
    WorktreeValid -- "No: Failed validation" --> AskUser

    %% ========================================
    %% STORY DISCOVERY PHASE
    %% ========================================
    %% FENCE: STORY-FIRST PLANNING (from planning-standard.yml)
    %% Story discovery MUST occur BEFORE phase determination.
    %% This ensures plans are anchored to user stories from the start.
    %% Guideline: modules/AgenticGuidance/assets/guidelines/planning-standard.yml#Story-First Planning
    WorktreeValid -- "Yes: Verified" --> StoryDiscovery[Run Story Discovery]

    subgraph StoryDiscovery_SG ["Story Discovery Subgraph"]
        %% STORY DISCOVERY vs STORY GENERATION:
        %% - Discovery: Find story IDs via `agentic stories find` (what stories exist)
        %% - Generation: Create story content files (what stories should exist if none found)
        %% - Validation: Verify story files have complete content (success_criteria, journey, testing)
        %% Both discovery AND content validation must pass before phase determination.
        %%
        %% Discover affected user stories using CLI before phase planning begins.
        %% Stories provide acceptance criteria that feed into UAT and phase decisions.
        %% ESCAPE HATCH RULES: planning-standard.yml#escape_hatch_rules
        %%   allowed_plan_types: [infrastructure, guidance, internal_tooling]
        %%   blocked_plan_types: [build, test] — MUST have stories, no escape
        StoryDiscovery --> RunStoryFind[Run: agentic stories find --project relevant_project]
        RunStoryFind --> StoriesFound{Stories Found?}

        %% Stories found - record and validate content exists
        StoriesFound -- "Yes: Stories Identified" --> RecordStories[Record affected_stories in Plan Metadata]
        RecordStories --> ValidateStoryContent[Validate Story Content Exists]
        ValidateStoryContent --> StoryFilesExist{Story Files Found?}

        %% Happy path: story files exist with complete content
        StoryFilesExist -- "Yes: Complete Content" --> StoryContextReady[Story Context Ready for Planners]

        %% Missing story files: need generation
        StoryFilesExist -- "No: Missing Files" --> CheckStoryCreationTasks{Has story_creation_tasks?}
        CheckStoryCreationTasks -- "Yes: Will Generate" --> NoteStoryGeneration[Note: Story generation in teach phase]
        NoteStoryGeneration --> StoryContextReady
        CheckStoryCreationTasks -- "No: Missing Tasks" --> BlockMissingStories((BLOCK: Story generation required but not planned))

        %% Incomplete story content: need fixes
        StoryFilesExist -- "Incomplete: Missing Fields" --> BlockIncompleteStories((BLOCK: Story content incomplete - missing success_criteria or journey))

        %% No stories found - check escape_hatch_rules from planning-standard.yml
        StoriesFound -- "No: None Found" --> CheckEscapeHatchRules{Plan Type in blocked_plan_types?}

        %% BLOCKED: build and test plans MUST have stories
        CheckEscapeHatchRules -- "Yes: build/test" --> BlockNoStories((BLOCK: Stories Required for build/test Plans))

        %% ALLOWED: infrastructure, guidance, internal_tooling may proceed with rationale
        CheckEscapeHatchRules -- "No: infrastructure/guidance/tooling" --> RequireRationale{Has no_stories_rationale?}
        RequireRationale -- "Yes: Valid Rationale" --> RecordNoStoriesRationale[Record no_stories_rationale]
        RecordNoStoriesRationale --> StoryContextReady
        RequireRationale -- "No: Missing Rationale" --> BlockNoRationale((BLOCK: Provide no_stories_rationale))
    end

    %% ========================================
    %% PHASE DETERMINATION
    %% ========================================
    %% Orchestration-planning agent analyzes objective and determines required phases.
    %% Possible phases: teach, build, test, cleanup, audit, uat
    %% - uat: User acceptance testing and story validation (PRIMARY SUCCESS CRITERIA)
    %% Each phase will get its own plan_<phase>.yml file
    StoryContextReady --> PhaseDetermination[Enter Phase Determination]

    subgraph PhaseDetermination_SG ["Phase Determination Subgraph"]
        %% Orchestration-planning determines phases based on objective type:
        %% - teach: guidance, process, or documentation improvements
        %% - build: code implementation or feature development
        %% - test: test strategy and validation tasks
        %% - cleanup: code cleanup or removal tasks
        %% - audit: plan folder compliance checks and file lifecycle validation
        %% - uat: user acceptance testing (PRIMARY SUCCESS CRITERIA - validates user journeys)
        %% Creates placeholder .yml files for each required phase
        PhaseDetermination --> AnalyzeObjective[Analyze Objective Type]
        AnalyzeObjective --> DeterminePhases[Determine Required Phases]
        DeterminePhases --> SelectLoopStrategies[Select Loop Strategies per Phase]
        SelectLoopStrategies --> PhasesDecided{Phases & Loops Decided?}

        %% List possible phases: teach, build, test, cleanup, audit, uat
        PhasesDecided -- "Yes" --> CreatePlaceholders[Create Phase Placeholder Files]
        PhasesDecided -- "No: Unclear" --> EscalatePhases((Ask User for Phase Guidance))
    end

    %% ========================================
    %% GUIDANCE CHANGE ROUTING
    %% ========================================
    %% Build plans may include guidance file modifications. When detected,
    %% the orchestration MUST include teach validation phase to ensure
    %% guidance quality. This prevents the CCI issue where 26
    %% agents were modified without validation.
    %%
    %% Detection: requires_teach_validation flag from planner-build
    %% Action: Insert teach validation phase after build tasks
    %% Reference: modules/AgenticGuidance/agents/orchestration/orchestration-planning/inputs.yml#guidance_change_routing
    CreatePlaceholders --> CheckGuidanceModifications{Guidance Files Modified?}

    subgraph GuidanceRouting_SG ["Guidance Change Routing Subgraph"]
        %% When guidance modifications detected, insert teach validation
        CheckGuidanceModifications -->|Yes: requires_teach_validation=true| IncludeTeachValidation[Include Teach Validation Phase]
        IncludeTeachValidation --> InsertAfterBuild[Position After Build Tasks]
        InsertAfterBuild --> AddSelfReview[Add Agent Self-Review Tasks]
        AddSelfReview --> AddGuidanceReview[Add Guidance Review Gate]
        AddGuidanceReview --> TeachValidationConfigured((Teach Validation Configured))
    end

    %% Both paths continue to planning loops
    CheckGuidanceModifications -->|No: Build-only| PlanningLoops
    TeachValidationConfigured --> PlanningLoops

    %% ========================================
    %% PLANNING LOOPS PHASE
    %% ========================================
    %% LOOP_DEFINITION: modules/AgenticGuidance/assets/definitions/agent-loops.yml#loop_types.planner-loop
    %% MAX_ITERATIONS: 5 (per planner-loop definition)
    %% ESCALATION: If max iterations reached without approval, stop and Ask User
    %%
    %% PLANNER_LOOP_TEMPLATE: Each phase loop follows identical pattern:
    %%   Check{Phase}Required? --Yes--> {Phase}PlanLoop --> SpawnPlanner{Phase} --> SpawnReviewer
    %%   --> {Phase}Approved? --No:Refine--> SpawnPlanner{Phase}Fix --> SpawnReviewer
    %%   --> {Phase}Approved? --Yes:Ready--> Check{NextPhase}Required?
    %%   Check{Phase}Required? --No--> Check{NextPhase}Required?
    %%
    %% AGENT_MAPPING (phase -> planner agent):
    %%   teach -> planner-guidance | build -> planner-build | test -> planner-test
    %%   cleanup -> planner-cleaning | audit -> planner-audit | uat -> planner-test
    %% NOTE: PlanningLoops now receives flow from GuidanceRouting_SG (see above)

    subgraph PlanningLoops_SG ["Planning Loops Subgraph"]
        %% PHASE SEQUENCE: teach -> build -> test -> cleanup -> audit -> uat -> AllPhasesPlanned
        %% Each phase uses PLANNER_LOOP_TEMPLATE with phase-specific agent from AGENT_MAPPING

        %% TEACH LOOP (planner-guidance)
        PlanningLoops --> CheckTeach{Teach Phase Required?}
        CheckTeach -- "Yes" --> TeachPlanLoop{Teach Planning Loop}
        TeachPlanLoop --> SpawnPlannerTeach[Spawn planner-guidance Agent]
        SpawnPlannerTeach --> SpawnTeachReviewer[Spawn planner-reviewer Agent]
        SpawnTeachReviewer --> TeachPlanApproved{Teach Plan Approved?}
        TeachPlanApproved -- "No: Refine" --> SpawnPlannerTeachFix[Spawn planner-guidance Agent]
        SpawnPlannerTeachFix --> SpawnTeachReviewer
        TeachPlanApproved -- "Yes: Ready" --> CheckBuild{Build Phase Required?}
        CheckTeach -- "No" --> CheckBuild

        %% BUILD LOOP (planner-build)
        CheckBuild -- "Yes" --> BuildPlanLoop{Build Planning Loop}
        BuildPlanLoop --> SpawnPlannerBuild[Spawn planner-build Agent]
        SpawnPlannerBuild --> SpawnBuildReviewer[Spawn planner-reviewer Agent]
        SpawnBuildReviewer --> BuildPlanApproved{Build Plan Approved?}
        BuildPlanApproved -- "No: Refine" --> SpawnPlannerBuildFix[Spawn planner-build Agent]
        SpawnPlannerBuildFix --> SpawnBuildReviewer
        BuildPlanApproved -- "Yes: Ready" --> CheckTest{Test Phase Required?}
        CheckBuild -- "No" --> CheckTest

        %% TEST LOOP (planner-test)
        CheckTest -- "Yes" --> TestPlanLoop{Test Planning Loop}
        TestPlanLoop --> SpawnPlannerTest[Spawn planner-test Agent]
        SpawnPlannerTest --> SpawnTestReviewer[Spawn planner-reviewer Agent]
        SpawnTestReviewer --> TestPlanApproved{Test Plan Approved?}
        TestPlanApproved -- "No: Refine" --> SpawnPlannerTestFix[Spawn planner-test Agent]
        SpawnPlannerTestFix --> SpawnTestReviewer
        TestPlanApproved -- "Yes: Ready" --> CheckCleanup{Cleanup Phase Required?}
        CheckTest -- "No" --> CheckCleanup

        %% CLEANUP LOOP (planner-cleaning)
        CheckCleanup -- "Yes" --> CleanupPlanLoop{Cleanup Planning Loop}
        CleanupPlanLoop --> SpawnPlannerCleanup[Spawn planner-cleaning Agent]
        SpawnPlannerCleanup --> SpawnCleanupReviewer[Spawn planner-reviewer Agent]
        SpawnCleanupReviewer --> CleanupPlanApproved{Cleanup Plan Approved?}
        CleanupPlanApproved -- "No: Refine" --> SpawnPlannerCleanupFix[Spawn planner-cleaning Agent]
        SpawnPlannerCleanupFix --> SpawnCleanupReviewer
        CleanupPlanApproved -- "Yes: Ready" --> CheckAudit{Audit Phase Required?}
        CheckCleanup -- "No" --> CheckAudit

        %% AUDIT LOOP (planner-audit) - validates plan folder compliance
        CheckAudit -- "Yes" --> AuditPlanLoop{Audit Planning Loop}
        AuditPlanLoop --> SpawnPlannerAudit[Spawn planner-audit Agent]
        SpawnPlannerAudit --> SpawnAuditReviewer[Spawn planner-reviewer Agent]
        SpawnAuditReviewer --> AuditPlanApproved{Audit Plan Approved?}
        AuditPlanApproved -- "No: Refine" --> SpawnPlannerAuditFix[Spawn planner-audit Agent]
        SpawnPlannerAuditFix --> SpawnAuditReviewer
        AuditPlanApproved -- "Yes: Ready" --> CheckUAT{UAT Phase Required?}
        CheckAudit -- "No" --> CheckUAT

        %% UAT LOOP (planner-test) - MANDATORY for build/test plans, validates user journeys
        %% FENCE: UAT IS MANDATORY (planning-standard.yml)
        %% blocked_plan_types (build, test) CANNOT skip UAT
        %% allowed_plan_types (infrastructure, guidance, internal_tooling) may skip with rationale
        CheckUAT -- "Yes" --> UATPlanLoop{UAT Planning Loop}
        UATPlanLoop --> SpawnPlannerTestUAT[Spawn planner-test Agent for UAT]
        SpawnPlannerTestUAT --> SpawnUATReviewer[Spawn planner-reviewer Agent]
        SpawnUATReviewer --> UATPlanApproved{UAT Plan Approved?}
        UATPlanApproved -- "No: Refine" --> SpawnPlannerTestUATFix[Spawn planner-test Agent]
        SpawnPlannerTestUATFix --> SpawnUATReviewer
        UATPlanApproved -- "Yes: Ready" --> AllPhasesPlanned[All Required Phases Planned]

        %% UAT SKIP GATE: Only allowed_plan_types may skip (with rationale)
        %% Reference: planning-standard.yml#escape_hatch_rules
        CheckUAT -- "No" --> CheckUATEscapeHatch{Plan Type in blocked_plan_types?}
        CheckUATEscapeHatch -- "Yes: build/test" --> BlockNoUAT((BLOCK: UAT Required for build/test Plans))
        CheckUATEscapeHatch -- "No: infrastructure/guidance/tooling" --> CheckUATRationale{Has no_stories_rationale?}
        CheckUATRationale -- "Yes: Valid" --> AllPhasesPlanned
        CheckUATRationale -- "No: Missing" --> BlockNoUATRationale((BLOCK: Provide Rationale to Skip UAT))
    end

    %% ========================================
    %% MMD GENERATION PHASE (DELEGATED)
    %% ========================================
    %% After all phase plans are complete, spawn planner-orchestration to generate
    %% the orchestration MMD. This follows the naming convention:
    %% - orchestration-* agents execute workflows
    %% - planner-* agents create planning artifacts (MMD is a planning artifact)
    %%
    %% AGENT: planner-orchestration
    %% INPUT: plan_folder_path (passed to planner-orchestration)
    %% OUTPUT: orchestration_<name>.mmd in the plan folder
    %%
    AllPhasesPlanned --> SpawnMMDGenerator[Spawn planner-orchestration Agent]

    subgraph MMDGeneration_SG ["MMD Generation Subgraph (Delegated)"]
        %% planner-orchestration handles all MMD generation logic:
        %% - Reading plan_*.yml files
        %% - Extracting phases and determining agent routing
        %% - Validating loop structures
        %% - Building the flowchart with correct node granularity
        %% - Writing and validating the MMD file
        %%
        %% See: modules/AgenticGuidance/agents/planner/planner-orchestration/process.yml
        SpawnMMDGenerator --> MMDAgentResult{planner-orchestration Succeeded?}
        MMDAgentResult -- "No: Failed" --> RetryMMD{Retry Count < 3?}
        RetryMMD -- "Yes" --> SpawnMMDGeneratorRetry[Spawn planner-orchestration Agent - Retry]
        SpawnMMDGeneratorRetry --> MMDAgentResult
        RetryMMD -- "No: Max Retries" --> EscalateMMD((Escalate: MMD Generation Failed))
        MMDAgentResult -- "Yes: MMD Generated" --> MMDReady[MMD Generation Complete]
    end

    MMDReady --> HumanApproval[Enter Human Approval Gate]

    %% ========================================
    %% HUMAN APPROVAL GATE
    %% ========================================
    %% POLICY: Human Approval Gate is for CLARIFICATION, not routine sign-off.
    %% If plan requirements are unambiguous, proceed without approval prompt.
    %% Only engage user when open questions or decision points exist.
    %%
    %% CONDITION: Check for open questions BEFORE presenting plan.
    %% - If all requirements clear AND no open questions: Auto-approve (proceed to output)
    %% - If requirements unclear OR open questions exist: Present for user approval
    %%
    %% QUESTION WORKFLOW CHECKPOINT:
    %% Before plan approval, check for pending questions requiring human input.
    %% Reference: modules/AgenticGuidance/assets/guidelines/question-workflow.yml
    %% CLI Commands (for human use):
    %% - agentic question list --plan <plan_folder> --status pending
    %% - agentic question show <question_id>
    %% - agentic question answer <question_id> --text "answer"
    %% Severity-based gating:
    %% - blocking: Cannot proceed without answer (halt execution)
    %% - high: Significant impact, recommend answer before execution
    %% - medium: Important clarification, can proceed with documented assumptions
    %% - low: Nice-to-have, does not block execution

    subgraph HumanApproval_SG ["Human Approval Gate Subgraph"]
        %% First check: Are there open questions requiring user input?
        %% Check plan folder's questions/pending/ directory for unanswered questions
        %% Reference CLI: agentic question list --plan <plan_folder> --status pending
        HumanApproval --> CheckOpenQuestions{Open Questions?}

        %% If questions exist, check severity to determine gating behavior
        CheckOpenQuestions -- "Yes: Pending Questions" --> CheckQuestionSeverity{Blocking Questions?}

        %% BLOCKING PATH: blocking severity questions MUST be answered
        %% Cannot proceed with plan execution until answered
        CheckQuestionSeverity -- "Yes: Blocking" --> HaltForAnswers[Halt: Blocking Questions Must Be Answered]
        HaltForAnswers --> ListBlockingQuestions[List Blocking Questions for User]
        ListBlockingQuestions --> WaitForAnswers((Wait for User to Answer via CLI))

        %% HIGH SEVERITY PATH: high severity questions should be answered
        %% Recommend answering but can proceed if user acknowledges
        CheckQuestionSeverity -- "No: High/Medium/Low Only" --> CheckHighQuestions{High Severity Questions?}
        CheckHighQuestions -- "Yes: High" --> WarnHighSeverity[Warn: High Severity Questions Pending]
        WarnHighSeverity --> PresentPlan[Present Complete Plan Summary]

        %% MEDIUM/LOW PATH: Can proceed with documented assumptions
        CheckHighQuestions -- "No: Medium/Low Only" --> NoteQuestions[Note: Questions Pending (Non-Blocking)]
        NoteQuestions --> PresentPlan

        %% AUTO-APPROVE PATH: No questions, clear requirements
        CheckOpenQuestions -- "No: Clear" --> MarkApproved[Mark Plan as Approved]

        %% MANUAL APPROVAL PATH: Questions exist or need user input
        PresentPlan --> ShowPhases[Display All Phase Plans]
        ShowPhases --> ShowMMD[Display Orchestration MMD]
        ShowMMD --> ShowTasks[Display Tasks per Phase]
        ShowTasks --> ShowCriteria[Display Success Criteria]
        ShowCriteria --> UserDecision{User Decision?}

        %% User approves - proceed to output
        UserDecision -- "Approved" --> MarkApproved

        %% User requests changes - return to planning loops with feedback
        UserDecision -- "Changes Requested" --> CaptureChanges[Capture User Feedback]
        CaptureChanges --> IdentifyAffectedPhases[Identify Affected Phase Plans]
        IdentifyAffectedPhases -.->|Return to Planning Loops| PlanningLoops

        %% User rejects - terminate with explanation
        UserDecision -- "Rejected" --> CaptureRejection[Capture Rejection Reason]
        CaptureRejection --> RejectEnd((End: Plan Rejected))
    end

    %% ========================================
    %% OUTPUT PHASE
    %% ========================================
    %% Output the approved plan folder path.
    %% Plan is ready for _orchestrate.yml entrypoints.
    MarkApproved --> OutputPhase[Generate Output]

    subgraph Output_SG ["Output Subgraph"]
        OutputPhase --> ReportPlanLocation[Report Live Plan Folder Path]
        ReportPlanLocation --> ReportPhases[Report Phases Created]
        ReportPhases --> ReportNextSteps[Report Next Steps: _orchestrate.yml]
    end

    ReportNextSteps --> End((End: Approved Plan Ready))

    %% ========================================
    %% STYLING
    %% ========================================
    %% Dotted lines for feedback loops (return paths from Human Approval)
    %% These represent plan refinement cycles based on user feedback
    %% Feedback loops in this MMD:
    %% - IdentifyAffectedPhases -.-> PlanningLoops (human feedback loop)
    %% NOTE: Edge indices must be recalculated if flowchart structure changes.
    %% The dashed edge style is applied via the -.-> syntax in Mermaid.
    classDef dashedstroke stroke-dasharray: 5 5;
