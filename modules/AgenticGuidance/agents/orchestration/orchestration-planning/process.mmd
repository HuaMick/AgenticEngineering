flowchart LR
    %% GOAL: Orchestrate planning agents to create executable plans without execution.
    %% PROFILE: Orchestration-Planning
    %% GUIDELINE: PLANNING ONLY policy - no execution, no exploration loops.
    %% GUIDELINE: User provides all necessary context in their prompt - no discovery phase.
    %% GUIDELINE: modules/AgenticGuidance/assets/definitions/plans.yml - Plan types and folder structure
    %% INPUT_PATH: modules/AgenticGuidance/agents/orchestration/orchestration-planning/inputs.yml
    %%
    %% ENTRYPOINT AWARENESS:
    %% This orchestrator is invoked via entrypoints that signal planning intent:
    %% - _plan_build.yml: Build/implementation planning (prioritize planner-build)
    %% - _plan_teach.yml: Teaching/guidance planning (prioritize planner-guidance)
    %% - _plan_test.yml: Test strategy planning (prioritize planner-test)
    %% The entrypoint intent influences phase determination and planner selection order.
    %%
    %% OUTPUTS (FENCE: Output must match declared schema before marking complete):
    %% - Plan folder: docs/plans/live/{plan_id}/ with required structure
    %% - README.md: Plan overview and folder structure
    %% - plan_live_*.yml: Phase plan files (build, test, teach, cleanup as needed)
    %% - orchestration_<name>.mmd: Orchestration flowchart for executor
    %% - Each plan file requires: name, status, phases fields
    %% - MMD schema reference: modules/AgenticGuidance/assets/definitions/plan-mmd-schema.yml
    %% - Plan schema reference: modules/AgenticGuidance/assets/examples/planner/YYMMDDRepo_Branch/plan_example.yml

    Start((Start)) --> LoadInputs[Load Context Inputs]

    %% ========================================
    %% INPUT VALIDATION PHASE
    %% ========================================
    %% Verify all required context is provided in the user prompt.
    %% Unlike orchestration-build, NO exploration phase - user supplies context.
    LoadInputs --> ReviewInputs[Review All Listed Inputs]
    ReviewInputs --> CheckInputs{All Inputs Found?}

    %% If inputs are missing, ask user for clarification (no self-healing search)
    CheckInputs -- "No: Missing" --> AskUser((Ask User for Clarification))

    %% Proceed when context is verified
    CheckInputs -- "Yes: Verified" --> SpawnDeployWorktree[Spawn deploy-worktree Agent]

    %% ========================================
    %% WORKTREE & PLAN FOLDER SETUP
    %% ========================================
    %% CLI OFFLOAD: Use agentic-cli commands for worktree and plan operations
    %% - agentic worktree create: Creates worktree with plan folder
    %% - agentic worktree status: Verifies worktree configuration
    %% - agentic plan validate: Validates plan folder structure
    %% deploy-worktree agent orchestrates CLI commands
    SpawnDeployWorktree --> VerifyWorktree[Verify Worktree via CLI: agentic worktree status]
    VerifyWorktree --> ValidatePlanFolder[Validate Plan Folder via CLI: agentic plan validate]
    ValidatePlanFolder --> WorktreeValid{Worktree & Plan Valid?}
    WorktreeValid -- "No: Failed verification" --> AskUser

    %% ========================================
    %% PHASE DETERMINATION
    %% ========================================
    %% Orchestration-planning agent analyzes objective and determines required phases.
    %% Possible phases: teach, build, test, cleanup
    %% Each phase will get its own plan_live_<phase>.yml file
    WorktreeValid -- "Yes: Verified" --> PhaseDetermination[Enter Phase Determination]

    subgraph PhaseDetermination_SG ["Phase Determination Subgraph"]
        %% Orchestration-planning determines phases based on objective type:
        %% - teach: guidance, process, or documentation improvements
        %% - build: code implementation or feature development
        %% - test: test strategy and validation tasks
        %% - cleanup: code cleanup, audit, or removal tasks
        %% Creates placeholder .yml files for each required phase
        PhaseDetermination --> AnalyzeObjective[Analyze Objective Type]
        AnalyzeObjective --> DeterminePhases[Determine Required Phases]
        DeterminePhases --> PhasesDecided{Phases Decided?}

        %% List possible phases: teach, build, test, cleanup
        PhasesDecided -- "Yes" --> CreatePlaceholders[Create Phase Placeholder Files]
        PhasesDecided -- "No: Unclear" --> EscalatePhases((Ask User for Phase Guidance))
    end

    %% ========================================
    %% PLANNING LOOPS PHASE
    %% ========================================
    %% LOOP_DEFINITION: modules/AgenticGuidance/assets/definitions/agent-loops.yml#loop_types.planner-loop
    %% MAX_ITERATIONS: 5 (per planner-loop definition)
    %% ESCALATION: If max iterations reached without approval, stop and Ask User
    %%
    %% For each required phase, spawn specialized planner + reviewer loop:
    %% - planner-guidance: Teaching/guidance plans
    %% - planner-build: Build/implementation plans
    %% - planner-test: Test strategy plans
    %% - planner-cleaning: Cleanup/audit plans
    CreatePlaceholders --> PlanningLoops[Enter Planning Loops Phase]

    subgraph PlanningLoops_SG ["Planning Loops Subgraph"]
        %% ----------------------------------------
        %% TEACH PLANNING LOOP (if teach phase required)
        %% ----------------------------------------
        PlanningLoops --> CheckTeach{Teach Phase Required?}
        CheckTeach -- "Yes" --> TeachPlanLoop{Teach Planning Loop}

        TeachPlanLoop --> SpawnPlannerTeach[Spawn planner-guidance Agent]
        SpawnPlannerTeach --> SpawnTeachReviewer[Spawn planner-reviewer Agent]
        SpawnTeachReviewer --> TeachPlanApproved{Teach Plan Approved?}

        %% Iterative refinement for teach plan
        TeachPlanApproved -- "No: Refine" --> SpawnPlannerTeachFix[Spawn planner-guidance Agent]
        SpawnPlannerTeachFix --> SpawnTeachReviewer

        TeachPlanApproved -- "Yes: Ready" --> CheckBuild{Build Phase Required?}
        CheckTeach -- "No" --> CheckBuild

        %% ----------------------------------------
        %% BUILD PLANNING LOOP (if build phase required)
        %% ----------------------------------------
        CheckBuild -- "Yes" --> BuildPlanLoop{Build Planning Loop}

        BuildPlanLoop --> SpawnPlannerBuild[Spawn planner-build Agent]
        SpawnPlannerBuild --> SpawnBuildReviewer[Spawn planner-reviewer Agent]
        SpawnBuildReviewer --> BuildPlanApproved{Build Plan Approved?}

        %% Iterative refinement for build plan
        BuildPlanApproved -- "No: Refine" --> SpawnPlannerBuildFix[Spawn planner-build Agent]
        SpawnPlannerBuildFix --> SpawnBuildReviewer

        BuildPlanApproved -- "Yes: Ready" --> CheckTest{Test Phase Required?}
        CheckBuild -- "No" --> CheckTest

        %% ----------------------------------------
        %% TEST PLANNING LOOP (if test phase required)
        %% ----------------------------------------
        CheckTest -- "Yes" --> TestPlanLoop{Test Planning Loop}

        TestPlanLoop --> SpawnPlannerTest[Spawn planner-test Agent]
        SpawnPlannerTest --> SpawnTestReviewer[Spawn planner-reviewer Agent]
        SpawnTestReviewer --> TestPlanApproved{Test Plan Approved?}

        %% Iterative refinement for test plan
        TestPlanApproved -- "No: Refine" --> SpawnPlannerTestFix[Spawn planner-test Agent]
        SpawnPlannerTestFix --> SpawnTestReviewer

        TestPlanApproved -- "Yes: Ready" --> CheckCleanup{Cleanup Phase Required?}
        CheckTest -- "No" --> CheckCleanup

        %% ----------------------------------------
        %% CLEANUP PLANNING LOOP (if cleanup phase required)
        %% ----------------------------------------
        CheckCleanup -- "Yes" --> CleanupPlanLoop{Cleanup Planning Loop}

        CleanupPlanLoop --> SpawnPlannerCleanup[Spawn planner-cleaning Agent]
        SpawnPlannerCleanup --> SpawnCleanupReviewer[Spawn planner-reviewer Agent]
        SpawnCleanupReviewer --> CleanupPlanApproved{Cleanup Plan Approved?}

        %% Iterative refinement for cleanup plan
        CleanupPlanApproved -- "No: Refine" --> SpawnPlannerCleanupFix[Spawn planner-cleaning Agent]
        SpawnPlannerCleanupFix --> SpawnCleanupReviewer

        CleanupPlanApproved -- "Yes: Ready" --> AllPhasesPlanned[All Required Phases Planned]
        CheckCleanup -- "No" --> AllPhasesPlanned
    end

    %% ========================================
    %% MMD GENERATION PHASE
    %% ========================================
    %% After all phase plans are complete, generate orchestration MMD for executor.
    %% The MMD defines agent routing, feedback triggers, and execution flow.
    %%
    %% SCHEMA REFERENCE: modules/AgenticGuidance/assets/definitions/plan-mmd-schema.yml
    %% COMPONENT EXAMPLES: modules/AgenticGuidance/assets/examples/planner/components/
    %% OUTPUT LOCATION: <plan_folder>/live/orchestration_<name>.mmd
    %%
    AllPhasesPlanned --> GenerateMMD[Enter MMD Generation Phase]

    subgraph MMDGeneration_SG ["MMD Generation Subgraph"]
        %% Step 1: Read all plan_*.yml files from plan folder
        GenerateMMD --> ReadPlanFiles[Read All plan_*.yml Files from Plan Folder]
        ReadPlanFiles --> ExtractPhases[Extract Phases from Plan Files]

        %% Step 2: Determine agent routing based on phase types
        %% AGENT_ROUTING mapping:
        %% - teach phases -> teacher agents (teacher-update-guidance)
        %% - build phases -> builder agents (build-python, build-flutter)
        %% - test phases -> tester agents (test-runner)
        %% - cleanup phases -> builder agents (cleanup tasks use builders)
        ExtractPhases --> DetermineRouting[Determine AGENT_ROUTING Based on Phase Types]

        %% Step 3: Generate MMD metadata block
        DetermineRouting --> GenerateMetadata[Generate MMD Metadata]
        %% Required MMD Metadata (per plan-mmd-schema.yml):
        %% - PHASES: List of all phases extracted from plan files
        %% - AGENT_ROUTING: Phase -> agent type mapping (teach->teacher, build->builder, test->tester, cleanup->builder)
        %% - FEEDBACK_TRIGGERS: Failure handling paths (TEST_FAILURE, BUILD_FAILURE, etc.)
        %% - STATUS: Initial pending state for all phases (Phase=pending format)

        %% Step 4: Build flowchart structure
        GenerateMetadata --> BuildFlowchart[Build Flowchart Structure]
        %% Flowchart structure requirements:
        %% - Start node and input validation phase
        %% - Phase execution nodes for each plan phase
        %% - Test/fix loops per agent-loops.yml definitions
        %% - Feedback paths for re-planning (dashed lines)
        %% - Success/escalation endpoints
        %% - Proper subgraph encapsulation per schema

        %% Step 5: Write MMD to output location
        BuildFlowchart --> WriteMMD[Write orchestration_<name>.mmd to plan_folder/live/]
        %% Output: <plan_folder>/live/orchestration_<name>.mmd
        %% where <name> is derived from plan folder name

        %% Step 6: Validate MMD against schema before proceeding
        WriteMMD --> ValidateMMD{MMD Valid Against Schema?}
        ValidateMMD -- "No: Schema Error" --> FixMMD[Fix MMD Structure Per Schema]
        FixMMD --> BuildFlowchart
        ValidateMMD -- "Yes: Valid" --> MMDReady[MMD Generation Complete]
    end

    MMDReady --> HumanApproval[Enter Human Approval Gate]

    %% ========================================
    %% HUMAN APPROVAL GATE
    %% ========================================
    %% Present complete plan AND orchestration MMD to user for final approval.
    %% User can: approve, request changes, or reject.
    %% This is the critical gate before plan is marked ready for execution.

    subgraph HumanApproval_SG ["Human Approval Gate Subgraph"]
        HumanApproval --> PresentPlan[Present Complete Plan Summary]
        PresentPlan --> ShowPhases[Display All Phase Plans]
        ShowPhases --> ShowMMD[Display Orchestration MMD]
        ShowMMD --> ShowTasks[Display Tasks per Phase]
        ShowTasks --> ShowCriteria[Display Success Criteria]
        ShowCriteria --> UserDecision{User Decision?}

        %% User approves - proceed to output
        UserDecision -- "Approved" --> MarkApproved[Mark Plan as Approved]

        %% User requests changes - return to planning loops with feedback
        UserDecision -- "Changes Requested" --> CaptureChanges[Capture User Feedback]
        CaptureChanges --> IdentifyAffectedPhases[Identify Affected Phase Plans]
        IdentifyAffectedPhases -.->|Return to Planning Loops| PlanningLoops

        %% User rejects - terminate with explanation
        UserDecision -- "Rejected" --> CaptureRejection[Capture Rejection Reason]
        CaptureRejection --> RejectEnd((End: Plan Rejected))
    end

    %% ========================================
    %% OUTPUT PHASE
    %% ========================================
    %% Output the approved plan folder path.
    %% Plan is ready for _orchestrate.yml entrypoints.
    MarkApproved --> OutputPhase[Generate Output]

    subgraph Output_SG ["Output Subgraph"]
        OutputPhase --> ReportPlanLocation[Report Live Plan Folder Path]
        ReportPlanLocation --> ReportPhases[Report Phases Created]
        ReportPhases --> ReportNextSteps[Report Next Steps: _orchestrate.yml]
    end

    ReportNextSteps --> End((End: Approved Plan Ready))

    %% ========================================
    %% STYLING
    %% ========================================
    %% Dotted lines for feedback loops (return paths from Human Approval and MMD fix)
    %% These represent plan refinement cycles based on user feedback
    %% Edge index 58 is: FixMMD --> BuildFlowchart (MMD fix loop)
    %% Edge index 70 is: IdentifyAffectedPhases -.-> PlanningLoops (human feedback loop)
    classDef dashedstroke stroke-dasharray: 5 5;
    linkStyle 58,70 stroke:#888,stroke-width:2px,stroke-dasharray: 5 5;
