%% =============================================================================
%% CCI BOOTSTRAP (CLI Context Injection) - EXECUTE FIRST
%% =============================================================================
%% Before following this flowchart, run:
%%   agentic context bootstrap --role orchestration-friction -j
%%   agentic plan task current -j
%%
%% This provides structured context more efficiently than file exploration.
%% =============================================================================

flowchart LR
    %% ========================================
    %% ORCHESTRATION: FRICTION ANALYSIS
    %% ========================================
    %% GOAL: Analyze LangSmith traces for friction patterns and present recommendations.
    %% PROFILE: Orchestration-Analysis
    %% INPUT_PATH: modules/AgenticGuidance/agents/orchestration/orchestration-friction/inputs.yml
    %%
    %% FRICTION_PATTERNS: FP-001 through FP-006 (see inputs.yml for definitions)
    %% RESOLUTION_TYPES: GUIDANCE_UPDATE, CLI_OFFLOAD, ASSET_UPDATE
    %% STATUS: Analysis=pending
    %%
    %% NOTE: This orchestration is READ-ONLY.
    %% No automatic changes are made - user decides on resolution approach.

    Start((Start)) --> LoadInputs[Load Inputs from inputs.yml]

    %% ========================================
    %% INPUT VALIDATION PHASE
    %% ========================================
    subgraph InputValidation_SG ["Input Validation Subgraph"]
        LoadInputs --> ValidateProject{Project Configured?}
        ValidateProject -- "No: Missing" --> CheckEnvVar{CC_LANGSMITH_PROJECT Set?}
        CheckEnvVar -- "No" --> AskUser((Ask User for Project))
        CheckEnvVar -- "Yes" --> UseEnvProject[Use CC_LANGSMITH_PROJECT]
        ValidateProject -- "Yes: Provided" --> SetProject[Set Project Name]
        UseEnvProject --> SetProject
        SetProject --> ValidateLangSmith{LangSmith Available?}
        ValidateLangSmith -- "No: Unavailable" --> ErrorNoLangSmith((Error: LangSmith Not Available))
        ValidateLangSmith -- "Yes: Available" --> BeginAnalysis[Begin Analysis Phase]
    end

    %% ========================================
    %% TRACE QUERY PHASE
    %% ========================================
    subgraph TraceQuery_SG ["Trace Query Subgraph"]
        BeginAnalysis --> QueryTraces[Query LangSmith Traces]
        QueryTraces --> FilterByTimeframe[Filter by Lookback Days]
        FilterByTimeframe --> ApplyLimit[Apply Run Limit]
        ApplyLimit --> TracesReady{Traces Found?}
        TracesReady -- "No: Empty" --> ReportNoTraces[Report: No Traces in Timeframe]
        TracesReady -- "Yes: Found" --> CheckRLMRequired
    end

    ReportNoTraces --> End

    %% ========================================
    %% RLM VALIDATION PHASE
    %% ========================================
    %% Validates that RLM (Runaway LLM Mitigation) was properly used for large trace sets.
    %% RLM requires CONTEXT_* and ACCUMULATOR_* variables to manage incremental processing.
    %% RECOVERY: Instead of hard-failing, directs sub-agent to retry with RLM patterns enabled.
    subgraph RLM_Validation_SG ["RLM Validation"]
        CheckRLMRequired{Traces > 100?}
        CheckRLMRequired -- "No: Under Threshold" --> BeginDetection[Begin Pattern Detection]
        CheckRLMRequired -- "Yes: Over Threshold" --> ValidateRLMUsage{RLM Variables Present?}
        ValidateRLMUsage -- "Yes: CONTEXT_*/ACCUMULATOR_*" --> BeginDetection
        ValidateRLMUsage -- "No: Missing" --> RLMRecoveryDirective
    end

    %% ========================================
    %% RLM RECOVERY MECHANISM
    %% ========================================
    %% Graceful recovery instead of hard-fail: signals sub-agent to retry with RLM enabled.
    %% Follows agent loop patterns for recovery per process.yml mandates.
    subgraph RLM_Recovery_SG ["RLM Recovery"]
        RLMRecoveryDirective[/"Directive: Retry with RLM decomposition patterns as mandated by process.yml"/]
        RLMRecoveryDirective --> IncrementRetryCount[Increment RLM Retry Counter]
        IncrementRetryCount --> CheckRetryLimit{Retry Count <= 2?}
        CheckRetryLimit -- "Yes: Can Retry" --> EnableRLMPatterns[Enable CONTEXT_*/ACCUMULATOR_* Variables]
        EnableRLMPatterns --> LogRecoveryAttempt[Log Recovery Attempt to Sub-Agent]
        LogRecoveryAttempt --> CheckRLMRequired
        CheckRetryLimit -- "No: Max Retries Exceeded" --> ErrorRLMRequired((Error: RLM Required - Recovery Failed))
    end

    ErrorRLMRequired --> ReportRLMError[Report: RLM Recovery Exhausted After 2 Retries]
    ReportRLMError --> End

    %% ========================================
    %% FRICTION DETECTION PHASE
    %% ========================================
    %% Run all 6 friction pattern detectors
    subgraph FrictionDetection_SG ["Friction Detection Subgraph"]
        BeginDetection --> DetectRetries[Detect FP-001: Excessive Retries]
        DetectRetries --> DetectDrift[Detect FP-002: Exploration Drift]
        DetectDrift --> DetectMissingContext[Detect FP-003: Missing Context]
        DetectMissingContext --> DetectSchemaViolations[Detect FP-004: Schema Violations]
        DetectSchemaViolations --> DetectConventionViolations[Detect FP-005: Convention Violations]
        DetectConventionViolations --> DetectAutomatable[Detect FP-006: Automatable Patterns]
        DetectAutomatable --> AggregateFindings[Aggregate All Findings]
    end

    %% ========================================
    %% CLASSIFICATION PHASE
    %% ========================================
    subgraph Classification_SG ["Classification Subgraph"]
        AggregateFindings --> PatternsFound{Any Patterns Found?}
        PatternsFound -- "No: Clean" --> ReportClean[Report: No Friction Detected]
        PatternsFound -- "Yes: Found" --> ClassifySeverity[Classify by Severity]
        ClassifySeverity --> GenerateRecommendations[Generate Resolution Recommendations]
    end

    ReportClean --> End

    %% ========================================
    %% RECOMMENDATION PHASE
    %% ========================================
    subgraph Recommendation_SG ["Recommendation Subgraph"]
        GenerateRecommendations --> MapToResolutions[Map Patterns to Resolution Types]
        MapToResolutions --> IdentifyTargetFiles[Identify Target Files for Changes]
        IdentifyTargetFiles --> CompileEvidence[Compile Evidence from Traces]
        CompileEvidence --> BuildReport[Build Friction Report]
    end

    %% ========================================
    %% OUTPUT PHASE
    %% ========================================
    subgraph Output_SG ["Output Subgraph"]
        BuildReport --> PresentFindings[Present Findings to User]
        PresentFindings --> ShowPatterns[Show Detected Patterns with Severity]
        ShowPatterns --> ShowRecommendations[Show Resolution Recommendations]
        ShowRecommendations --> ShowEvidence[Show Evidence from Traces]
        ShowEvidence --> UserDecision{User: Choose Next Step}

        %% User decides what to do with findings
        UserDecision -- "Implement GUIDANCE_UPDATE" --> SuggestGuidancePlan[Suggest _plan_teach.yml]
        UserDecision -- "Implement CLI_OFFLOAD" --> SuggestCLIPlan[Suggest CLI Implementation Plan]
        UserDecision -- "Implement ASSET_UPDATE" --> SuggestAssetPlan[Suggest Asset Update Plan]
        UserDecision -- "Defer / No Action" --> ReportSaved[Save Report for Later]
    end

    SuggestGuidancePlan --> End((End: User Decides))
    SuggestCLIPlan --> End
    SuggestAssetPlan --> End
    ReportSaved --> End

    %% ========================================
    %% STYLING
    %% ========================================
    classDef entrypoint fill:#90EE90,stroke:#228B22
    classDef exitpoint fill:#FFB6C1,stroke:#DC143C
    classDef userpoint fill:#87CEEB,stroke:#4682B4
    classDef errorpoint fill:#FF6B6B,stroke:#CC0000
    classDef recoverypoint fill:#FFA500,stroke:#FF8C00
    class Start entrypoint
    class End exitpoint
    class AskUser,UserDecision userpoint
    class ErrorRLMRequired,ErrorNoLangSmith errorpoint
    class RLMRecoveryDirective recoverypoint
