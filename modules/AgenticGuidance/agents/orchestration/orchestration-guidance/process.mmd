flowchart LR
    %% GOAL: Orchestrate agents to update the agent guidance system through a context engineering process.
    %% PROFILE: Orchestration-Context-Engineer
    %% OUTPUT: Completed plans and audit reports in docs/plans/completed/
    %% GUIDELINE: Strict NO CODE policy - context engineering for guidance only.
    %% GUIDELINE: Every execution issue or audit failure MUST trigger re-invocation of orchestration-planning.
    %% INPUT_PATH: modules/AgenticGuidance/agents/orchestration/orchestration-guidance/inputs.yml

    Start((Start)) --> LoadInputs[Load Context Inputs]

    %% Input Verification & Search Logic: Ensure we have all necessary context from inputs.yml
    LoadInputs --> ReviewInputs[Review All Listed Inputs]
    ReviewInputs --> CheckInputs{All Inputs Found?}

    %% If inputs are missing, attempt to self-heal by searching
    CheckInputs -- "No: Missing" --> SearchInputs[Search for Missing Inputs]
    SearchInputs --> Found{Found?}

    %% If found elsewhere, update paths to maintain continuity
    Found -- "Yes: Update paths" --> UpdateRefs[Update References & Flag]
    UpdateRefs --> ReviewInputs

    %% Critical failure: Stop and ask user if context cannot be resolved
    Found -- "No: Stop" --> AskUser((Ask User for Clarification))

    %% Proceed only when context is fully loaded and verified
    CheckInputs -- "Yes: Verified" --> CheckExistingPlan{Pre-approved Plan Exists?}

    %% ========================================
    %% WORKTREE & PLAN FOLDER SETUP (CLI OFFLOAD)
    %% ========================================
    %% If pre-approved plan provided, skip init. If new plan needed, use CLI directly.
    %% CLI command: agentic plan init <branch> --description <desc>
    %% Enforces YYMMDDXX_description naming convention programmatically.
    %% Exit codes: 0=success, 1=worktree failed, 2=folder exists, 3=invalid input
    CheckExistingPlan -- "Yes: Has Plan Path" --> ValidatePlanFolder[Validate Plan Folder via CLI: agentic plan validate]
    CheckExistingPlan -- "No: Needs Init" --> InitPlanFolder[Run CLI: agentic plan init branch --description desc]
    InitPlanFolder --> CheckInitResult{CLI Exit Code 0?}
    CheckInitResult -- "No: Exit 1/2/3" --> AskUser((Ask User for Clarification))
    CheckInitResult -- "Yes: Success" --> ValidatePlanFolder
    ValidatePlanFolder --> WorktreeValid{Plan Folder Valid?}
    WorktreeValid -- "No: Failed verification" --> AskUser

    %% ========================================
    %% PLANNING DELEGATION
    %% ========================================
    %% orchestration-guidance accepts two modes:
    %% MODE 1: Pre-approved plan provided via approved_plan_path input
    %%   - Skip planning, proceed directly to execution
    %%   - Used when orchestration-planning was invoked independently
    %%
    %% MODE 2: No pre-approved plan
    %%   - Delegate to orchestration-planning agent
    %%   - orchestration-planning handles:
    %%     - Implementation Planning Loop (planner-guidance + reviewer)
    %%     - Test-Guidance Planning Loop (planner-guidance-testing + reviewer)
    %%     - Human approval gate
    %%   - Receive approved plan folder path upon completion
    %%
    %% OUTPUT FROM orchestration-planning:
    %%   - Approved plan folder with implementation and test phases
    %%   - Plan status: approved
    %%   - Ready for execution phase
    %%
    %% FEEDBACK LOOP ENTRY POINTS:
    %% This phase receives feedback from three downstream validation points:
    %% 1. Implementation Issues: Execution-time problems → Re-invoke orchestration-planning
    %% 2. Walkthrough Failures: Guidance gaps from test-guidance-simulator → Re-invoke orchestration-planning
    %% 3. Final Audit Failures: Output quality issues → Re-invoke orchestration-planning

    WorktreeValid -- "Yes: Verified" --> CheckApprovedPlan{Pre-Approved Plan Provided?}

    %% MODE 1: Pre-approved plan path provided
    CheckApprovedPlan -- "Yes: Has Approved Plan" --> LoadApprovedPlan[Load Approved Plan from Input Path]
    LoadApprovedPlan --> ValidatePlanFormat{Plan Format Valid?}

    %% Validate plan structure before proceeding
    ValidatePlanFormat -- "No: Invalid" --> AskUser

    %% MODE 2: No pre-approved plan - delegate to orchestration-planning
    CheckApprovedPlan -- "No: Needs Planning" --> SpawnOrchestrationPlanning[Spawn orchestration-planning Agent]
    SpawnOrchestrationPlanning --> WaitForApproval{Plan Approved?}

    %% User rejected or cancelled during planning
    WaitForApproval -- "No: User Rejected/Cancelled" --> AskUser

    %% Receive approved plan from orchestration-planning
    WaitForApproval -- "Yes: Approved" --> ReceiveApprovedPlan[Receive Approved Plan Folder Path]

    %% Both paths converge to execution phase
    ValidatePlanFormat -- "Yes: Valid" --> SpawnTeachers
    ReceiveApprovedPlan --> SpawnTeachers

    %% ========================================
    %% EXECUTION PHASE: Implement Guidance Changes
    %% ========================================
    %% TEACHER ROUTING:
    %% SpawnTeachers selects teacher agents based on task type in approved plan:
    %% - teacher-update-guidance: Process/inputs/manifest updates (agent-level guidance)
    %% - teacher-update-assets: Shared definitions/guidelines/examples (shared assets)
    %% Routing criteria from approved plan task metadata:
    %% - target_file contains "agents/" → teacher-update-guidance
    %% - target_file contains "assets/" → teacher-update-assets
    %% ========================================
    %% Execution begins ONLY after approved plan is loaded/received:
    %% - Implementation plan approved (from orchestration-planning)
    %% - Test plan approved (from orchestration-planning)
    SpawnTeachers[Spawn teacher agents] --> ExecutePhases[Execute Implementation Phases]

    %% Continuous monitoring for execution-time issues
    ExecutePhases --> ImplIssues{Implementation Issues?}

    %% Fail-Fast & Recover: Return to planning by re-invoking orchestration-planning
    ImplIssues -- "Yes: Failed" --> OffloadIssues[Offload to Appropriate Agent]
    OffloadIssues --> UpdatePlan[Update Live Plan]
    UpdatePlan -.->|Return to Planning| SpawnOrchestrationPlanning

    %% ========================================
    %% GUIDANCE VALIDATION PHASE
    %% ========================================
    %% Execute the test-guidance plan from orchestration-planning
    %% Uses guidance-blind-test strategy to validate guidance completeness
    %% COMPONENT: modules/AgenticGuidance/assets/examples/planner/components/guidance_blind_test.mmd
    %% LOOP_DEFINITION: modules/AgenticGuidance/assets/definitions/agent-loops.yml#loop_types.guidance-test-loop
    %% MAX_ITERATIONS: 3 (per guidance-test-loop definition)
    %% ESCALATION: If max iterations reached without passing validation, stop and Ask User with gap context
    ImplIssues -- "No: Done" --> ExecuteGuidanceTests[Execute Test-Guidance Phases]
    ExecuteGuidanceTests --> SpawnGuidanceSim[Spawn test-guidance-simulator]
    %% PLAN STATUS UPDATE: Consume test results and update plan task statuses
    %% Reference: modules/AgenticGuidance/assets/guidelines/orchestration-policy.yml - Plan Status Management rule
    %% This step ensures task statuses reflect test outcomes before evaluating overall guidance validity
    SpawnGuidanceSim --> UpdateTestStatuses[Update Plan Task Statuses from Test Results]
    UpdateTestStatuses --> GuidancePassed{Guidance Valid?}

    %% ========================================
    %% GUIDANCE REPAIR LOOP: Failing walkthrough tests trigger re-planning
    %% ========================================
    %% BEHAVIOR: When test-guidance-simulator reports friction points:
    %% 1. Categorize gaps by severity (CRITICAL/HIGH/MEDIUM/LOW from test-guidance-simulator)
    %% 2. Update plan with gap categorization context for orchestration-planning
    %% 3. Re-invoke orchestration-planning with:
    %%    - Structured friction report from test-guidance-simulator
    %%    - Specific guidance gaps with suggested fixes
    %%    - Context on which walkthrough scenarios failed
    %% 4. orchestration-planning re-executes BOTH planning loops
    %% 5. Track iteration count against guidance-test-loop max_iterations (3)
    %% ========================================
    GuidancePassed -- "No: Gaps Found" --> CategorizeGaps[Categorize Friction Points & Route to Teacher Agents]
    CategorizeGaps --> UpdatePlanGaps[Update Plan with Walkthrough Failure Details]
    UpdatePlanGaps -.->|Return to Planning| SpawnOrchestrationPlanning

    %% ========================================
    %% FINAL AUDIT PHASE
    %% ========================================
    GuidancePassed -- "Yes: Verified" --> SpawnAudit[Spawn test-final-output Audit]
    SpawnAudit --> FinalAudit{Final Audit Passed?}

    %% If audit fails, re-invoke orchestration-planning for correction
    FinalAudit -- "No: Failed" --> UpdatePlanIssues[Update Plan with Audit Issues]
    UpdatePlanIssues -.->|Return to Planning| SpawnOrchestrationPlanning

    %% ========================================
    %% FINALIZATION
    %% ========================================
    %% Success: All criteria met. Finalize the work.
    FinalAudit -- "Yes: Verified" --> MoveCompleted[Copy Completed Work to docs/plans/completed/]
    MoveCompleted --> End((End))

    %% COPY planning folder to completed/ (not move) - live/ may continue with follow-on work
    %% Only user moves completed/ folders to archived/ subdirectory

    %% Styling for feedback loops (return paths to orchestration-planning)
    %% These dotted lines represent quality improvement cycles that re-invoke planning
    classDef dashedstroke stroke-dasharray: 5 5;
    linkStyle 26,33,37 stroke:#888,stroke-width:2px,stroke-dasharray: 5 5;
