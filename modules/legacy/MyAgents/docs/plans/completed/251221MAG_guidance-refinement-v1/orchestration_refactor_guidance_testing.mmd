            X3 --> X4{Phase 4 Complete?}
        end

        subgraph AUDIT["Final Audit"]
            X4 -->|Yes| Y1[Spawn test-final-output-agent]

            %% DECISION: Independent audit of all phases
            %% JUSTIFICATION: Per process.mmd, final audit ensures objective verification
            Y1 --> Y2["Audit All Phases:<br/>- Phase 1: PASS (3/3 criteria)<br/>- Phase 2: PASS (3/3 criteria)<br/>- Phase 3: PASS (3/3 criteria)<br/>- Phase 4: PASS (4/4 criteria)<br/>- Cross-file consistency: PASS"]
            Y2 --> Y3{Audit Passed?}
        end
    end

    subgraph FINALIZE["FINALIZATION"]
        Y3 -->|"Yes: All Criteria Met"| Z1[Update Plan Status to Completed]
        Z1 --> Z2[Generate Orchestration Summary]
        Z2 --> Z3((End))
    end

    %% Failure paths
    F -->|No| FAIL1[Ask User for Clarification]
    K -->|No| REFINE[Spawn planner-teach for Refinement]
    REFINE --> H
    P4 -->|No| FAIL2[Escalate to Planning Loop]
    T1 -->|No| FAIL2
    T2 -->|No| FAIL2
    V4 -->|No| FAIL2
    X4 -->|No| FAIL2
    Y3 -->|No| FAIL2
    FAIL2 -.->|Return to Planning| G

